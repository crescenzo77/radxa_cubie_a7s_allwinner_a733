@@ -480,13 +480,18 @@ static const struct clk_parent_data nsi_parents[] = {
 	{ .hw = &pll_periph0_480M_clk.common.hw },
 	{ .hw = &pll_de_3x_clk.common.hw },
 };
-static SUNXI_CCU_MP_DATA_WITH_MUX_GATE_FEAT(nsi_clk, "nsi", nsi_parents, 0x580,
+
+#define SUN60I_A733_NSI_REG		0x580
+static SUNXI_CCU_MP_DATA_WITH_MUX_GATE_FEAT(nsi_clk, "nsi", nsi_parents,
+					    SUN60I_A733_NSI_REG,
 					    0, 5,	/* M */
 					    0, 0,	/* no P */
 					    24, 3,	/* mux */
 					    BIT(31),	/* gate */
-					    0, CCU_FEATURE_UPDATE_BIT);
-static SUNXI_CCU_GATE_DATA(bus_nsi_clk, "bus-nsi", hosc, 0x584, BIT(0), 0);
+					    CLK_IS_CRITICAL,
+					    CCU_FEATURE_UPDATE_BIT);
+static SUNXI_CCU_GATE_DATA(bus_nsi_clk, "bus-nsi", hosc, 0x584, BIT(0),
+			   CLK_IS_CRITICAL);
 
 static const struct clk_parent_data mbus_parents[] = {
 	{ .hw = &sys_24M_clk.hw },
@@ -540,9 +545,9 @@ static SUNXI_CCU_GATE_HWS(ahb_usb_sys_clk, "ahb-usb-sys", ahb_hws,
 static SUNXI_CCU_GATE_HWS(ahb_msi_lite0_clk, "ahb-msi-lite0", ahb_hws,
 			  0x5c0, BIT(16), 0);
 static SUNXI_CCU_GATE_HWS(ahb_store_clk, "ahb-store", ahb_hws,
-			  0x5c0, BIT(24), 0);
+			  0x5c0, BIT(24), CLK_IS_CRITICAL);
 static SUNXI_CCU_GATE_HWS(ahb_cpus_clk, "ahb-cpus", ahb_hws,
-			  0x5c0, BIT(28), 0);
+			  0x5c0, BIT(28), CLK_IS_CRITICAL);
 
 static SUNXI_CCU_GATE_HWS(mbus_iommu0_clk, "mbus-iommu0", mbus_hws,
 			  0x5e0, BIT(0), 0);
@@ -563,9 +568,9 @@ static SUNXI_CCU_GATE_HWS(mbus_vid_in_clk, "mbus-vid-in", mbus_hws,
 static SUNXI_CCU_GATE_HWS(mbus_serdes_clk, "mbus-serdes", mbus_hws,
 			  0x5e0, BIT(28), 0);
 static SUNXI_CCU_GATE_HWS(mbus_msi_lite0_clk, "mbus-msi-lite0", mbus_hws,
-			  0x5e0, BIT(29), 0);
+			  0x5e0, BIT(29), CLK_IS_CRITICAL);
 static SUNXI_CCU_GATE_HWS(mbus_store_clk, "mbus-store", mbus_hws,
-			  0x5e0, BIT(30), 0);
+			  0x5e0, BIT(30), CLK_IS_CRITICAL);
 static SUNXI_CCU_GATE_HWS(mbus_msi_lite2_clk, "mbus-msi-lite2", mbus_hws,
 			  0x5e0, BIT(31), 0);
 
@@ -2343,6 +2348,13 @@ static int sun60i_a733_ccu_probe(struct platform_device *pdev)
 		writel(val, reg + pll_regs[i]);
 	}
 
+	/*
+	 * Boot firmware can leave the NSI mux/divider configuration pending;
+	 * commit it before fabric consumers start probing.
+	 */
+	val = readl(reg + SUN60I_A733_NSI_REG);
+	writel(val | CCU_SUNXI_UPDATE_BIT, reg + SUN60I_A733_NSI_REG);
+
 	/* Enforce m1 = 0 for PLL_AUDIO0 */
 	val = readl(reg + SUN60I_A733_PLL_AUDIO0_REG);
 	val &= ~BIT(1);
