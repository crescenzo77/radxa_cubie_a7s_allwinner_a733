From 902646b270d61015c821dc5b8eef8b2a64146efe Mon Sep 17 00:00:00 2001
From: Enzo Adriano <enzo.adriano.code@gmail.com>
Date: Sat, 13 Jun 2026 02:02:24 -0400
Subject: [PATCH 2/4] clk: sunxi-ng: a733: keep storage and NSI fabric clocks
 critical

Several A733 fabric clocks sit between storage bus masters and memory but
are not represented as ordinary device consumers. Letting the unused-clock
walk gate these clocks can leave SDMMC0 unable to complete its internal
clock/update or normal IDMA path even though the host controller itself has
probed.

Keep the storage AHB/MBUS lane and the NSI fabric clocks enabled. This is
the conservative hardware-verified shape for now: storage-fabric keepalive
removes the SDMMC0 clock-update timeout, and the same storage/NSI fabric
set together with the NSI update-bit commit lets SDMMC0 normal IDMA
enumerate the card and mount the root filesystem.

The mbus-msi-lite0 gate was part of the verified storage-fabric bundle. A
narrower comparison without mbus-msi-lite0 did not reach SDMMC0
initialization, so keep the full evidence-preserving bundle until a better
fabric model or narrower hardware result replaces it.

This was tested on Radxa Cubie A7S hardware.

Signed-off-by: Enzo Adriano <enzo.adriano.code@gmail.com>
---
 drivers/clk/sunxi-ng/ccu-sun60i-a733.c | 12 +++++++-----
 1 file changed, 7 insertions(+), 5 deletions(-)

diff --git a/drivers/clk/sunxi-ng/ccu-sun60i-a733.c b/drivers/clk/sunxi-ng/ccu-sun60i-a733.c
index 4718161920b7..8816c5cee319 100644
--- a/drivers/clk/sunxi-ng/ccu-sun60i-a733.c
+++ b/drivers/clk/sunxi-ng/ccu-sun60i-a733.c
@@ -485,8 +485,10 @@ static SUNXI_CCU_MP_DATA_WITH_MUX_GATE_FEAT(nsi_clk, "nsi", nsi_parents, 0x580,
 					    0, 0,	/* no P */
 					    24, 3,	/* mux */
 					    BIT(31),	/* gate */
-					    0, CCU_FEATURE_UPDATE_BIT);
-static SUNXI_CCU_GATE_DATA(bus_nsi_clk, "bus-nsi", hosc, 0x584, BIT(0), 0);
+					    CLK_IS_CRITICAL,
+					    CCU_FEATURE_UPDATE_BIT);
+static SUNXI_CCU_GATE_DATA(bus_nsi_clk, "bus-nsi", hosc, 0x584, BIT(0),
+			   CLK_IS_CRITICAL);
 
 static const struct clk_parent_data mbus_parents[] = {
 	{ .hw = &sys_24M_clk.hw },
@@ -540,7 +542,7 @@ static SUNXI_CCU_GATE_HWS(ahb_usb_sys_clk, "ahb-usb-sys", ahb_hws,
 static SUNXI_CCU_GATE_HWS(ahb_msi_lite0_clk, "ahb-msi-lite0", ahb_hws,
 			  0x5c0, BIT(16), 0);
 static SUNXI_CCU_GATE_HWS(ahb_store_clk, "ahb-store", ahb_hws,
-			  0x5c0, BIT(24), 0);
+			  0x5c0, BIT(24), CLK_IS_CRITICAL);
 /*
  * The CPU reaches the R-CCU and RTC register windows through this bridge
  * into the CPUS/R domain. Keep it enabled so later R-domain register
@@ -568,9 +570,9 @@ static SUNXI_CCU_GATE_HWS(mbus_vid_in_clk, "mbus-vid-in", mbus_hws,
 static SUNXI_CCU_GATE_HWS(mbus_serdes_clk, "mbus-serdes", mbus_hws,
 			  0x5e0, BIT(28), 0);
 static SUNXI_CCU_GATE_HWS(mbus_msi_lite0_clk, "mbus-msi-lite0", mbus_hws,
-			  0x5e0, BIT(29), 0);
+			  0x5e0, BIT(29), CLK_IS_CRITICAL);
 static SUNXI_CCU_GATE_HWS(mbus_store_clk, "mbus-store", mbus_hws,
-			  0x5e0, BIT(30), 0);
+			  0x5e0, BIT(30), CLK_IS_CRITICAL);
 static SUNXI_CCU_GATE_HWS(mbus_msi_lite2_clk, "mbus-msi-lite2", mbus_hws,
 			  0x5e0, BIT(31), 0);
 
