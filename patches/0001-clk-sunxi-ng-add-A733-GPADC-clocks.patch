From 82de2f86036a5ac5db64f076ca39de3fa777fcc0 Mon Sep 17 00:00:00 2001
From: Enzo <enzo.adriano.code@gmail.com>
Date: Thu, 4 Jun 2026 08:42:39 -0400
Subject: [PATCH 1/3] clk: sunxi-ng: add A733 GPADC clocks

---
 drivers/clk/sunxi-ng/ccu-sun60i-a733.c      | 7 +++++++
 include/dt-bindings/clock/sun60i-a733-ccu.h | 2 ++
 include/dt-bindings/reset/sun60i-a733-ccu.h | 1 +
 3 files changed, 10 insertions(+)

diff --git a/drivers/clk/sunxi-ng/ccu-sun60i-a733.c b/drivers/clk/sunxi-ng/ccu-sun60i-a733.c
index bfd2fc64fa1f..1a97b0e59d84 100644
--- a/drivers/clk/sunxi-ng/ccu-sun60i-a733.c
+++ b/drivers/clk/sunxi-ng/ccu-sun60i-a733.c
@@ -44,6 +44,8 @@ static SUNXI_CCU_GATE_DATA(bus_i2c9_clk, "bus-i2c9", hosc, 0xe80, BIT(9), 0);
 static SUNXI_CCU_GATE_DATA(bus_i2c10_clk, "bus-i2c10", hosc, 0xe80, BIT(10), 0);
 static SUNXI_CCU_GATE_DATA(bus_i2c11_clk, "bus-i2c11", hosc, 0xe80, BIT(11), 0);
 static SUNXI_CCU_GATE_DATA(bus_i2c12_clk, "bus-i2c12", hosc, 0xe80, BIT(12), 0);
+static SUNXI_CCU_GATE_DATA(gpadc_clk, "gpadc", hosc, 0x9ec, BIT(31), 0);
+static SUNXI_CCU_GATE_DATA(bus_gpadc_clk, "bus-gpadc", hosc, 0x9ec, BIT(0), 0);
 static SUNXI_CCU_GATE_DATA(usb_ohci0_clk, "usb-ohci0", hosc, 0xa70, BIT(31), 0);
 static SUNXI_CCU_GATE_DATA(bus_otg_clk, "bus-otg", hosc, 0xa8c, BIT(0), 0);
 static SUNXI_CCU_GATE_DATA(bus_ehci0_clk, "bus-ehci0", hosc, 0xa8c, BIT(1), 0);
@@ -76,6 +78,8 @@ static struct ccu_common *sun60i_a733_ccu_clks[] = {
 	&bus_i2c10_clk.common,
 	&bus_i2c11_clk.common,
 	&bus_i2c12_clk.common,
+	&gpadc_clk.common,
+	&bus_gpadc_clk.common,
 	&usb_ohci0_clk.common,
 	&bus_otg_clk.common,
 	&bus_ehci0_clk.common,
@@ -111,6 +115,8 @@ static struct clk_hw_onecell_data sun60i_a733_hw_clks = {
 		[CLK_BUS_I2C10]	= &bus_i2c10_clk.common.hw,
 		[CLK_BUS_I2C11]	= &bus_i2c11_clk.common.hw,
 		[CLK_BUS_I2C12]	= &bus_i2c12_clk.common.hw,
+		[CLK_GPADC]	= &gpadc_clk.common.hw,
+		[CLK_BUS_GPADC]	= &bus_gpadc_clk.common.hw,
 		[CLK_USB_OHCI0]	= &usb_ohci0_clk.common.hw,
 		[CLK_BUS_OTG]	= &bus_otg_clk.common.hw,
 		[CLK_BUS_EHCI0]	= &bus_ehci0_clk.common.hw,
@@ -144,6 +150,7 @@ static struct ccu_reset_map sun60i_a733_ccu_resets[] = {
 	[RST_BUS_I2C10]	= { 0xe80, BIT(26) },
 	[RST_BUS_I2C11]	= { 0xe80, BIT(27) },
 	[RST_BUS_I2C12]	= { 0xe80, BIT(28) },
+	[RST_BUS_GPADC]	= { 0x9ec, BIT(16) },
 	[RST_USB_PHY0]	= { 0xa8c, BIT(16) },
 	[RST_BUS_OTG]	= { 0xa8c, BIT(17) },
 	[RST_BUS_EHCI0]	= { 0xa8c, BIT(18) },
diff --git a/include/dt-bindings/clock/sun60i-a733-ccu.h b/include/dt-bindings/clock/sun60i-a733-ccu.h
index e67d6ed27dc4..0c20e416f402 100644
--- a/include/dt-bindings/clock/sun60i-a733-ccu.h
+++ b/include/dt-bindings/clock/sun60i-a733-ccu.h
@@ -21,6 +21,8 @@
 #define CLK_BUS_I2C10		171
 #define CLK_BUS_I2C11		172
 #define CLK_BUS_I2C12		173
+#define CLK_GPADC		186
+#define CLK_BUS_GPADC		187
 #define CLK_USB_OHCI0		214
 #define CLK_BUS_OTG		215
 #define CLK_BUS_EHCI0		216
diff --git a/include/dt-bindings/reset/sun60i-a733-ccu.h b/include/dt-bindings/reset/sun60i-a733-ccu.h
index ca288ca24012..b637aed5616c 100644
--- a/include/dt-bindings/reset/sun60i-a733-ccu.h
+++ b/include/dt-bindings/reset/sun60i-a733-ccu.h
@@ -18,6 +18,7 @@
 #define RST_BUS_I2C10		58
 #define RST_BUS_I2C11		59
 #define RST_BUS_I2C12		60
+#define RST_BUS_GPADC		67
 #define RST_USB_PHY0		81
 #define RST_BUS_OTG		82
 #define RST_BUS_EHCI0		83
-- 
