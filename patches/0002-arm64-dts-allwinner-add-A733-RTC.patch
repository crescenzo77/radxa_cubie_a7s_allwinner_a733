From 5d2fe25afbc6885ca673e5b8262e2ba21e510844 Mon Sep 17 00:00:00 2001
From: Enzo <enzo@homelab.local>
Date: Thu, 4 Jun 2026 18:31:38 -0400
Subject: [PATCH 2/2] arm64: dts: allwinner: add A733 RTC

---
 arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi | 12 ++++++++++++
 1 file changed, 12 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi b/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
index 86da09277a38..5f85fabbe8bc 100644
--- a/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
@@ -273,6 +273,18 @@ pck600: power-controller@7060000 {
 			#power-domain-cells = <1>;
 		};
 
+		rtc: rtc@7090000 {
+			compatible = "allwinner,sun60i-a733-rtc",
+				     "allwinner,sun55i-a523-rtc",
+				     "allwinner,sun50i-r329-rtc";
+			reg = <0x07090000 0x400>;
+			interrupts = <GIC_SPI 196 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&r_ccu CLK_BUS_R_RTC>, <&osc24M>,
+				 <&r_ccu CLK_R_AHB>;
+			clock-names = "bus", "hosc", "ahb";
+			#clock-cells = <1>;
+		};
+
 		r_i2c0: i2c@7083000 {
 			compatible = "allwinner,sun60i-a733-i2c",
 				     "allwinner,sun8i-v536-i2c",
-- 
2.53.0

