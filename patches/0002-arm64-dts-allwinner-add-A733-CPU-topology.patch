From 3f570debaa281028efdf9c6c5e18f06b979591ad Mon Sep 17 00:00:00 2001
From: Enzo <enzo.adriano.code@gmail.com>
Date: Sun, 31 May 2026 17:42:43 -0400
Subject: [PATCH 2/2] arm64: dts: allwinner: add A733 CPU topology

Describe the A733 CPU clusters with a cpu-map.

The preserved vendor DT and live device tree both describe CPUs 0-5 as one
Cortex-A55 cluster.  CPUs 6-7 are one Cortex-A76 cluster.  Mainline can use
that topology for scheduler decisions without adding any vendor-only OPP,
idle-state, regulator, or power-domain data.

Keep the map ordered by logical core number.  Do not copy the dump order.
The phandles still point at the same CPU nodes.
The ordered form is easier to review.
---
 .../arm64/boot/dts/allwinner/sun60i-a733.dtsi | 38 +++++++++++++++++++
 1 file changed, 38 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi b/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
index 753b5a81da38..6e935404f527 100644
--- a/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
@@ -68,6 +68,44 @@ cpu7: cpu@700 {
 			reg = <0x700>;
 			enable-method = "psci";
 		};
+
+		cpu-map {
+			cluster0 {
+				core0 {
+					cpu = <&cpu0>;
+				};
+
+				core1 {
+					cpu = <&cpu1>;
+				};
+
+				core2 {
+					cpu = <&cpu2>;
+				};
+
+				core3 {
+					cpu = <&cpu3>;
+				};
+
+				core4 {
+					cpu = <&cpu4>;
+				};
+
+				core5 {
+					cpu = <&cpu5>;
+				};
+			};
+
+			cluster1 {
+				core0 {
+					cpu = <&cpu6>;
+				};
+
+				core1 {
+					cpu = <&cpu7>;
+				};
+			};
+		};
 	};
 
 	osc24M: osc24M-clk {
-- 
