From 6c727d6a0102cf784b659ae5f506723e9bae5d00 Mon Sep 17 00:00:00 2001
From: Crescenzo <crescenzo@gmail.com>
Date: Tue, 2 Jun 2026 01:43:18 -0400
Subject: [PATCH 1/4] clk: sunxi-ng: add A733 GMAC0 bus gate

Prepare the next A733 Ethernet slice by exposing only the GMAC0 bus
clock and reset that are needed before a disabled MAC node can be
validated.

Keep this deliberately narrower than the vendor DTB. The Cubie A7S
vendor tree exposes more GMAC clocks and two reset lines, but the
mainline A523 reference uses a single GMAC0 bus clock/reset for the
matching 0x04500000 controller, and the public A733 CCU RFC names
CLK_BUS_GMAC0 and RST_BUS_GMAC0 at the 0x141c gate/reset register.

Do not add PHY, PTP, GMAC1, board enablement, delay properties, or PHY
reset handling yet. Those still need separate evidence from schema,
driver, and hardware tests.

Signed-off-by: Crescenzo <crescenzo@gmail.com>
---
 drivers/clk/sunxi-ng/ccu-sun60i-a733.c      | 5 +++++
 drivers/clk/sunxi-ng/ccu-sun60i-a733.h      | 2 +-
 include/dt-bindings/clock/sun60i-a733-ccu.h | 1 +
 include/dt-bindings/reset/sun60i-a733-ccu.h | 1 +
 4 files changed, 8 insertions(+), 1 deletion(-)

diff --git a/drivers/clk/sunxi-ng/ccu-sun60i-a733.c b/drivers/clk/sunxi-ng/ccu-sun60i-a733.c
index e08e28f9c4d6..ff8a6eee618b 100644
--- a/drivers/clk/sunxi-ng/ccu-sun60i-a733.c
+++ b/drivers/clk/sunxi-ng/ccu-sun60i-a733.c
@@ -31,11 +31,14 @@ static SUNXI_CCU_GATE_DATA(mmc0_clk, "mmc0", hosc, 0xd00, BIT(31), 0);
 static SUNXI_CCU_GATE_DATA(bus_mmc0_clk, "bus-mmc0", hosc, 0xd0c, BIT(0), 0);
 static SUNXI_CCU_GATE_HWS(bus_uart0_clk, "bus-uart0", apb_uart_hws,
 			  0xe00, BIT(0), 0);
+static SUNXI_CCU_GATE_DATA(bus_gmac0_clk, "bus-gmac0", hosc,
+			   0x141c, BIT(0), 0);
 
 static struct ccu_common *sun60i_a733_ccu_clks[] = {
 	&mmc0_clk.common,
 	&bus_mmc0_clk.common,
 	&bus_uart0_clk.common,
+	&bus_gmac0_clk.common,
 };
 
 static struct clk_hw_onecell_data sun60i_a733_hw_clks = {
@@ -45,6 +48,7 @@ static struct clk_hw_onecell_data sun60i_a733_hw_clks = {
 		[CLK_MMC0]	= &mmc0_clk.common.hw,
 		[CLK_BUS_MMC0]	= &bus_mmc0_clk.common.hw,
 		[CLK_BUS_UART0]	= &bus_uart0_clk.common.hw,
+		[CLK_BUS_GMAC0]	= &bus_gmac0_clk.common.hw,
 	},
 	.num	= CLK_NUMBER,
 };
@@ -52,6 +56,7 @@ static struct clk_hw_onecell_data sun60i_a733_hw_clks = {
 static struct ccu_reset_map sun60i_a733_ccu_resets[] = {
 	[RST_BUS_MMC0]	= { 0xd0c, BIT(16) },
 	[RST_BUS_UART0]	= { 0xe00, BIT(16) },
+	[RST_BUS_GMAC0]	= { 0x141c, BIT(16) },
 };
 
 static const struct sunxi_ccu_desc sun60i_a733_ccu_desc = {
diff --git a/drivers/clk/sunxi-ng/ccu-sun60i-a733.h b/drivers/clk/sunxi-ng/ccu-sun60i-a733.h
index 212c1a7fc801..2765999811f1 100644
--- a/drivers/clk/sunxi-ng/ccu-sun60i-a733.h
+++ b/drivers/clk/sunxi-ng/ccu-sun60i-a733.h
@@ -6,6 +6,6 @@
 #include <dt-bindings/clock/sun60i-a733-ccu.h>
 #include <dt-bindings/reset/sun60i-a733-ccu.h>
 
-#define CLK_NUMBER		(CLK_BUS_UART0 + 1)
+#define CLK_NUMBER		(CLK_BUS_GMAC0 + 1)
 
 #endif /* _CCU_SUN60I_A733_H_ */
diff --git a/include/dt-bindings/clock/sun60i-a733-ccu.h b/include/dt-bindings/clock/sun60i-a733-ccu.h
index e24fbc94a4a3..362aefde4e30 100644
--- a/include/dt-bindings/clock/sun60i-a733-ccu.h
+++ b/include/dt-bindings/clock/sun60i-a733-ccu.h
@@ -8,5 +8,6 @@
 #define CLK_MMC0		143
 #define CLK_BUS_MMC0		144
 #define CLK_BUS_UART0		154
+#define CLK_BUS_GMAC0		233
 
 #endif /* _DT_BINDINGS_CLK_SUN60I_A733_CCU_H_ */
diff --git a/include/dt-bindings/reset/sun60i-a733-ccu.h b/include/dt-bindings/reset/sun60i-a733-ccu.h
index b975662439b2..30810197b4d2 100644
--- a/include/dt-bindings/reset/sun60i-a733-ccu.h
+++ b/include/dt-bindings/reset/sun60i-a733-ccu.h
@@ -5,5 +5,6 @@
 
 #define RST_BUS_MMC0		35
 #define RST_BUS_UART0		41
+#define RST_BUS_GMAC0		95
 
 #endif /* _DT_BINDINGS_RST_SUN60I_A733_CCU_H_ */
