From 838084ec18ec5674fd8672d514513aa49aa89765 Mon Sep 17 00:00:00 2001
From: Enzo <enzo.adriano.code@gmail.com>
Date: Thu, 4 Jun 2026 01:57:36 -0400
Subject: [PATCH 4/4] arm64: dts: allwinner: add disabled A733 GMAC0 node

---
 .../arm64/boot/dts/allwinner/sun60i-a733.dtsi | 42 +++++++++++++++++++
 1 file changed, 42 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi b/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
index 8aec9ec23ee1..e05b3fcfcc70 100644
--- a/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
@@ -140,6 +140,17 @@ mmc0_pins: mmc0-pins {
 				drive-strength = <30>;
 				bias-pull-up;
 			};
+
+			rgmii0_pins: rgmii0-pins {
+				pins = "PH0", "PH1", "PH2", "PH3",
+				       "PH4", "PH5", "PH6", "PH7",
+				       "PH8", "PH9", "PH10", "PH11",
+				       "PH12", "PH13", "PH14", "PH15";
+				allwinner,pinmux = <5>;
+				function = "rgmii0";
+				drive-strength = <40>;
+				bias-pull-up;
+			};
 		};
 
 		ccu: clock-controller@2002000 {
@@ -173,6 +184,15 @@ gic: interrupt-controller@3400000 {
 			      <0x03460000 0xff004>;
 		};
 
+		syscon: syscon@3000000 {
+			compatible = "allwinner,sun60i-a733-system-control",
+				     "allwinner,sun50i-a64-system-control";
+			reg = <0x03000000 0x1000>;
+			#address-cells = <1>;
+			#size-cells = <1>;
+			ranges;
+		};
+
 		mmc0: mmc@4020000 {
 			compatible = "allwinner,sun60i-a733-mmc",
 				     "allwinner,sun20i-d1-mmc";
@@ -190,5 +210,27 @@ mmc0: mmc@4020000 {
 			#address-cells = <1>;
 			#size-cells = <0>;
 		};
+
+		gmac0: ethernet@4500000 {
+			compatible = "allwinner,sun60i-a733-gmac0",
+				     "allwinner,sun50i-a64-emac";
+			reg = <0x04500000 0x10000>;
+			interrupts = <GIC_SPI 172 IRQ_TYPE_LEVEL_HIGH>;
+			interrupt-names = "macirq";
+			clocks = <&ccu CLK_BUS_GMAC0>;
+			clock-names = "stmmaceth";
+			resets = <&ccu RST_BUS_GMAC0>;
+			reset-names = "stmmaceth";
+			pinctrl-names = "default";
+			pinctrl-0 = <&rgmii0_pins>;
+			syscon = <&syscon>;
+			status = "disabled";
+
+			mdio0: mdio {
+				compatible = "snps,dwmac-mdio";
+				#address-cells = <1>;
+				#size-cells = <0>;
+			};
+		};
 	};
 };
-- 
2.53.0

