From b1793111f53635d5408040eb60aa4b9d5a4ab169 Mon Sep 17 00:00:00 2001
From: Enzo <enzo@homelab.local>
Date: Thu, 4 Jun 2026 09:57:50 -0400
Subject: [PATCH 2/3] arm64: dts: allwinner: add A733 R-CCU NMI and R-I2C

Signed-off-by: Enzo <enzo@homelab.local>
---
 .../allwinner,sun7i-a20-sc-nmi.yaml           |  1 +
 .../arm64/boot/dts/allwinner/sun60i-a733.dtsi | 38 ++++++++++++++++++-
 2 files changed, 37 insertions(+), 2 deletions(-)

diff --git a/Documentation/devicetree/bindings/interrupt-controller/allwinner,sun7i-a20-sc-nmi.yaml b/Documentation/devicetree/bindings/interrupt-controller/allwinner,sun7i-a20-sc-nmi.yaml
index 06e3621a8c06..5af7beb8002c 100644
--- a/Documentation/devicetree/bindings/interrupt-controller/allwinner,sun7i-a20-sc-nmi.yaml
+++ b/Documentation/devicetree/bindings/interrupt-controller/allwinner,sun7i-a20-sc-nmi.yaml
@@ -27,6 +27,7 @@ properties:
       - const: allwinner,sun7i-a20-sc-nmi
       - const: allwinner,sun9i-a80-nmi
       - const: allwinner,sun55i-a523-nmi
+      - const: allwinner,sun60i-a733-nmi
       - items:
           - enum:
               - allwinner,sun8i-v3s-nmi
diff --git a/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi b/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
index 16490d4d246d..e1d754dc3214 100644
--- a/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
@@ -3,6 +3,8 @@
 #include <dt-bindings/interrupt-controller/arm-gic.h>
 #include <dt-bindings/clock/sun60i-a733-ccu.h>
 #include <dt-bindings/reset/sun60i-a733-ccu.h>
+#include <dt-bindings/clock/sun55i-a523-r-ccu.h>
+#include <dt-bindings/reset/sun55i-a523-r-ccu.h>
 
 / {
 	interrupt-parent = <&gic>;
@@ -237,13 +239,45 @@ rgmii0_pins: rgmii0-pins {
 		ccu: clock-controller@2002000 {
 			compatible = "allwinner,sun60i-a733-ccu";
 			reg = <0x02002000 0x2000>;
-			clocks = <&osc24M>, <&osc32k>, <&iosc>;
-			clock-names = "hosc", "losc", "iosc";
+			clocks = <&osc24M>, <&osc32k>, <&iosc>, <&osc24M>, <&osc24M>;
+			clock-names = "hosc", "losc", "iosc", "pll-periph",
+				      "pll-audio";
 			#clock-cells = <1>;
 			#reset-cells = <1>;
 		};
 
 
+		nmi_intc: interrupt-controller@7010320 {
+			compatible = "allwinner,sun60i-a733-nmi";
+			reg = <0x07010320 0xc>;
+			interrupts = <GIC_SPI 188 IRQ_TYPE_LEVEL_HIGH>;
+			interrupt-controller;
+			#interrupt-cells = <2>;
+		};
+
+		r_ccu: clock-controller@7010000 {
+			compatible = "allwinner,sun60i-a733-r-ccu";
+			reg = <0x07010000 0x340>;
+			clocks = <&osc24M>, <&osc32k>, <&iosc>, <&osc24M>, <&osc24M>;
+			clock-names = "hosc", "losc", "iosc", "pll-periph",
+				      "pll-audio";
+			#clock-cells = <1>;
+			#reset-cells = <1>;
+		};
+
+		r_i2c0: i2c@7083000 {
+			compatible = "allwinner,sun60i-a733-i2c",
+				     "allwinner,sun8i-v536-i2c",
+				     "allwinner,sun6i-a31-i2c";
+			reg = <0x07083000 0x400>;
+			interrupts = <GIC_SPI 203 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&r_ccu CLK_BUS_R_I2C0>;
+			resets = <&r_ccu RST_BUS_R_I2C0>;
+			status = "disabled";
+			#address-cells = <1>;
+			#size-cells = <0>;
+		};
+
 		wdt: watchdog@2050000 {
 			compatible = "allwinner,sun60i-a733-wdt";
 			reg = <0x02050000 0x20>;
-- 
2.53.0

