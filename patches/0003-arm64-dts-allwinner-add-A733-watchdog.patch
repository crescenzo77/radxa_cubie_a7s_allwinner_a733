From 22457bd14f4a73f067bd21fb34e10d9b992969bb Mon Sep 17 00:00:00 2001
From: Enzo <enzo.adriano.code@gmail.com>
Date: Thu, 4 Jun 2026 08:58:06 -0400
Subject: [PATCH 3/3] arm64: dts: allwinner: add A733 watchdog

Signed-off-by: Enzo <enzo.adriano.code@gmail.com>
---
 arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi b/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
index 1f80a409b119..16490d4d246d 100644
--- a/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
@@ -243,6 +243,16 @@ ccu: clock-controller@2002000 {
 			#reset-cells = <1>;
 		};
 
+
+		wdt: watchdog@2050000 {
+			compatible = "allwinner,sun60i-a733-wdt";
+			reg = <0x02050000 0x20>;
+			interrupts = <GIC_SPI 106 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&osc24M>, <&osc32k>;
+			clock-names = "hosc", "losc";
+			status = "okay";
+		};
+
 		uart0: serial@2500000 {
 			compatible = "snps,dw-apb-uart";
 			reg = <0x02500000 0x400>;
-- 
2.53.0

