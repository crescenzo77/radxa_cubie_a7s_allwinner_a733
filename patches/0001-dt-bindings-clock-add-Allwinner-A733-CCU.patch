From a86dd19d72a3f1cae8f42388221fa7fa4f3246d3 Mon Sep 17 00:00:00 2001
From: Crescenzo <crescenzo@gmail.com>
Date: Wed, 3 Jun 2026 20:57:04 -0400
Subject: [PATCH 1/2] dt-bindings: clock: add Allwinner A733 CCU

Add a binding for the main clock control unit found in the
Allwinner A733 SoC.

Assisted-by: OpenAI:GPT-5 Codex
---
 .../clock/allwinner,sun60i-a733-ccu.yaml      | 58 +++++++++++++++++++
 include/dt-bindings/clock/sun60i-a733-ccu.h   | 12 ++++
 include/dt-bindings/reset/sun60i-a733-ccu.h   |  9 +++
 3 files changed, 79 insertions(+)
 create mode 100644 Documentation/devicetree/bindings/clock/allwinner,sun60i-a733-ccu.yaml
 create mode 100644 include/dt-bindings/clock/sun60i-a733-ccu.h
 create mode 100644 include/dt-bindings/reset/sun60i-a733-ccu.h

diff --git a/Documentation/devicetree/bindings/clock/allwinner,sun60i-a733-ccu.yaml b/Documentation/devicetree/bindings/clock/allwinner,sun60i-a733-ccu.yaml
new file mode 100644
index 000000000000..afbe431fc1d9
--- /dev/null
+++ b/Documentation/devicetree/bindings/clock/allwinner,sun60i-a733-ccu.yaml
@@ -0,0 +1,58 @@
+# SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/clock/allwinner,sun60i-a733-ccu.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: Allwinner A733 Clock Control Unit
+
+maintainers:
+  - Andre Przywara <andre.przywara@arm.com>
+
+properties:
+  "#clock-cells":
+    const: 1
+
+  "#reset-cells":
+    const: 1
+
+  compatible:
+    const: allwinner,sun60i-a733-ccu
+
+  reg:
+    maxItems: 1
+
+  clocks:
+    items:
+      - description: High Frequency Oscillator, usually 24 MHz
+      - description: Low Frequency Oscillator, usually 32 kHz
+      - description: Internal Oscillator
+
+  clock-names:
+    items:
+      - const: hosc
+      - const: losc
+      - const: iosc
+
+required:
+  - "#clock-cells"
+  - "#reset-cells"
+  - compatible
+  - reg
+  - clocks
+  - clock-names
+
+additionalProperties: false
+
+examples:
+  - |
+    clock-controller@2002000 {
+        compatible = "allwinner,sun60i-a733-ccu";
+        reg = <0x02002000 0x2000>;
+        clocks = <&osc24M>, <&osc32k>, <&iosc>;
+        clock-names = "hosc", "losc", "iosc";
+        #clock-cells = <1>;
+        #reset-cells = <1>;
+    };
+
+...
diff --git a/include/dt-bindings/clock/sun60i-a733-ccu.h b/include/dt-bindings/clock/sun60i-a733-ccu.h
new file mode 100644
index 000000000000..e24fbc94a4a3
--- /dev/null
+++ b/include/dt-bindings/clock/sun60i-a733-ccu.h
@@ -0,0 +1,12 @@
+/* SPDX-License-Identifier: (GPL-2.0-only OR MIT) */
+
+#ifndef _DT_BINDINGS_CLK_SUN60I_A733_CCU_H_
+#define _DT_BINDINGS_CLK_SUN60I_A733_CCU_H_
+
+#define CLK_APB1		45
+#define CLK_APB_UART		46
+#define CLK_MMC0		143
+#define CLK_BUS_MMC0		144
+#define CLK_BUS_UART0		154
+
+#endif /* _DT_BINDINGS_CLK_SUN60I_A733_CCU_H_ */
diff --git a/include/dt-bindings/reset/sun60i-a733-ccu.h b/include/dt-bindings/reset/sun60i-a733-ccu.h
new file mode 100644
index 000000000000..b975662439b2
--- /dev/null
+++ b/include/dt-bindings/reset/sun60i-a733-ccu.h
@@ -0,0 +1,9 @@
+/* SPDX-License-Identifier: (GPL-2.0-only OR MIT) */
+
+#ifndef _DT_BINDINGS_RST_SUN60I_A733_CCU_H_
+#define _DT_BINDINGS_RST_SUN60I_A733_CCU_H_
+
+#define RST_BUS_MMC0		35
+#define RST_BUS_UART0		41
+
+#endif /* _DT_BINDINGS_RST_SUN60I_A733_CCU_H_ */
