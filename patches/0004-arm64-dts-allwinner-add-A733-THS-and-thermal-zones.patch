From 62b1c7fde45b6e7d84189a76db0136de399179b5 Mon Sep 17 00:00:00 2001
From: Enzo <enzo@homelab.local>
Date: Thu, 4 Jun 2026 08:48:30 -0400
Subject: [PATCH 4/4] arm64: dts: allwinner: add A733 THS and thermal zones

Signed-off-by: Enzo <enzo@homelab.local>
---
 .../arm64/boot/dts/allwinner/sun60i-a733.dtsi | 40 +++++++++++++++++++
 1 file changed, 40 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi b/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
index 9e65b633d885..40c1733d29dc 100644
--- a/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
@@ -142,6 +142,36 @@ pmu_a76: pmu-a76 {
 		interrupt-affinity = <&cpu6>, <&cpu7>;
 	};
 
+	thermal-zones {
+		cpu-big-thermal {
+			polling-delay-passive = <0>;
+			polling-delay = <0>;
+			thermal-sensors = <&ths 0>;
+
+			trips {
+				cpu_big_crit: cpu-big-crit {
+					temperature = <110000>;
+					hysteresis = <2000>;
+					type = "critical";
+				};
+			};
+		};
+
+		cpu-little-thermal {
+			polling-delay-passive = <0>;
+			polling-delay = <0>;
+			thermal-sensors = <&ths 3>;
+
+			trips {
+				cpu_little_crit: cpu-little-crit {
+					temperature = <110000>;
+					hysteresis = <2000>;
+					type = "critical";
+				};
+			};
+		};
+	};
+
 	psci {
 		compatible = "arm,psci-1.0", "arm,psci-0.2";
 		method = "smc";
@@ -413,6 +443,16 @@ syscon: syscon@3000000 {
 			ranges;
 		};
 
+		ths: thermal-sensor@2522000 {
+			compatible = "allwinner,sun60i-a733-ths";
+			reg = <0x02522000 0x500>;
+			interrupts = <GIC_SPI 39 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&ccu CLK_BUS_THS>;
+			clock-names = "bus";
+			resets = <&ccu RST_BUS_THS>;
+			#thermal-sensor-cells = <1>;
+		};
+
 		gpadc: adc@2521000 {
 			compatible = "allwinner,sun60i-a733-gpadc",
 				     "allwinner,sun20i-d1-gpadc";
-- 
2.53.0

