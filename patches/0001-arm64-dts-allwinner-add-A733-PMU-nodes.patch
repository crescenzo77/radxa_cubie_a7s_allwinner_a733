From 1694cd03f6bb9c564b51f0450dd89d8395de9479 Mon Sep 17 00:00:00 2001
From: Enzo <enzo.adriano.code@gmail.com>
Date: Sun, 31 May 2026 17:38:26 -0400
Subject: [PATCH 1/2] arm64: dts: allwinner: add A733 PMU nodes

Describe the A733 CPU PMUs using CPU-specific mainline compatibles and the
shared PMU PPI observed in the preserved vendor DT.

The vendor tree exposes a single arm,armv8-pmuv3 node, but the binding
reserves that generic compatible for software models.  A733 has six
Cortex-A55 CPUs and two Cortex-A76 CPUs.  Split the PMU description by CPU
type, and use interrupt-affinity to bind each PMU node to the CPUs that
implement it.

This keeps the performance-monitoring description tied to evidence from the
vendor/live device tree while avoiding a vendor-only shortcut that would be
weak in upstream review.
---
 arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi | 13 +++++++++++++
 1 file changed, 13 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi b/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
index e05b3fcfcc70..753b5a81da38 100644
--- a/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
@@ -91,6 +91,19 @@ iosc: internal-osc-clk {
 		clock-output-names = "iosc";
 	};
 
+	pmu_a55: pmu-a55 {
+		compatible = "arm,cortex-a55-pmu";
+		interrupts = <GIC_PPI 7 IRQ_TYPE_LEVEL_HIGH>;
+		interrupt-affinity = <&cpu0>, <&cpu1>, <&cpu2>,
+				     <&cpu3>, <&cpu4>, <&cpu5>;
+	};
+
+	pmu_a76: pmu-a76 {
+		compatible = "arm,cortex-a76-pmu";
+		interrupts = <GIC_PPI 7 IRQ_TYPE_LEVEL_HIGH>;
+		interrupt-affinity = <&cpu6>, <&cpu7>;
+	};
+
 	psci {
 		compatible = "arm,psci-1.0", "arm,psci-0.2";
 		method = "smc";
-- 
