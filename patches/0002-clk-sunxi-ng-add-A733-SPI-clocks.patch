From 1817037b8b89908ec35de8ed431fad5577efb365 Mon Sep 17 00:00:00 2001
From: Enzo <enzo@homelab.local>
Date: Thu, 4 Jun 2026 19:46:02 -0400
Subject: [PATCH 2/3] clk: sunxi-ng: add A733 SPI clocks

---
 drivers/clk/sunxi-ng/ccu-sun60i-a733.c      | 35 +++++++++++++++++++++
 include/dt-bindings/clock/sun60i-a733-ccu.h | 10 ++++++
 include/dt-bindings/reset/sun60i-a733-ccu.h |  5 +++
 3 files changed, 50 insertions(+)

diff --git a/drivers/clk/sunxi-ng/ccu-sun60i-a733.c b/drivers/clk/sunxi-ng/ccu-sun60i-a733.c
index a648b47fa730..1c7bc70ae103 100644
--- a/drivers/clk/sunxi-ng/ccu-sun60i-a733.c
+++ b/drivers/clk/sunxi-ng/ccu-sun60i-a733.c
@@ -58,6 +58,16 @@ static SUNXI_CCU_GATE_DATA(bus_i2c9_clk, "bus-i2c9", hosc, 0xe80, BIT(9), 0);
 static SUNXI_CCU_GATE_DATA(bus_i2c10_clk, "bus-i2c10", hosc, 0xe80, BIT(10), 0);
 static SUNXI_CCU_GATE_DATA(bus_i2c11_clk, "bus-i2c11", hosc, 0xe80, BIT(11), 0);
 static SUNXI_CCU_GATE_DATA(bus_i2c12_clk, "bus-i2c12", hosc, 0xe80, BIT(12), 0);
+static SUNXI_CCU_GATE_DATA(spi0_clk, "spi0", hosc, 0x940, BIT(31), 0);
+static SUNXI_CCU_GATE_DATA(spi1_clk, "spi1", hosc, 0x944, BIT(31), 0);
+static SUNXI_CCU_GATE_DATA(spi2_clk, "spi2", hosc, 0x948, BIT(31), 0);
+static SUNXI_CCU_GATE_DATA(spi3_clk, "spi3", hosc, 0x950, BIT(31), 0);
+static SUNXI_CCU_GATE_DATA(spi4_clk, "spi4", hosc, 0x954, BIT(31), 0);
+static SUNXI_CCU_GATE_DATA(bus_spi0_clk, "bus-spi0", hosc, 0x96c, BIT(0), 0);
+static SUNXI_CCU_GATE_DATA(bus_spi1_clk, "bus-spi1", hosc, 0x96c, BIT(1), 0);
+static SUNXI_CCU_GATE_DATA(bus_spi2_clk, "bus-spi2", hosc, 0x96c, BIT(2), 0);
+static SUNXI_CCU_GATE_DATA(bus_spi3_clk, "bus-spi3", hosc, 0x96c, BIT(4), 0);
+static SUNXI_CCU_GATE_DATA(bus_spi4_clk, "bus-spi4", hosc, 0x96c, BIT(5), 0);
 static SUNXI_CCU_GATE_DATA(gpadc_clk, "gpadc", hosc, 0x9ec, BIT(31), 0);
 static SUNXI_CCU_GATE_DATA(bus_gpadc_clk, "bus-gpadc", hosc, 0x9ec, BIT(0), 0);
 static SUNXI_CCU_GATE_DATA(bus_ths_clk, "bus-ths", hosc, 0x9fc, BIT(0), 0);
@@ -101,6 +111,16 @@ static struct ccu_common *sun60i_a733_ccu_clks[] = {
 	&bus_i2c10_clk.common,
 	&bus_i2c11_clk.common,
 	&bus_i2c12_clk.common,
+	&spi0_clk.common,
+	&spi1_clk.common,
+	&spi2_clk.common,
+	&spi3_clk.common,
+	&spi4_clk.common,
+	&bus_spi0_clk.common,
+	&bus_spi1_clk.common,
+	&bus_spi2_clk.common,
+	&bus_spi3_clk.common,
+	&bus_spi4_clk.common,
 	&gpadc_clk.common,
 	&bus_gpadc_clk.common,
 	&bus_ths_clk.common,
@@ -147,6 +167,16 @@ static struct clk_hw_onecell_data sun60i_a733_hw_clks = {
 		[CLK_BUS_I2C10]	= &bus_i2c10_clk.common.hw,
 		[CLK_BUS_I2C11]	= &bus_i2c11_clk.common.hw,
 		[CLK_BUS_I2C12]	= &bus_i2c12_clk.common.hw,
+		[CLK_SPI0]	= &spi0_clk.common.hw,
+		[CLK_BUS_SPI0]	= &bus_spi0_clk.common.hw,
+		[CLK_SPI1]	= &spi1_clk.common.hw,
+		[CLK_BUS_SPI1]	= &bus_spi1_clk.common.hw,
+		[CLK_SPI2]	= &spi2_clk.common.hw,
+		[CLK_BUS_SPI2]	= &bus_spi2_clk.common.hw,
+		[CLK_SPI3]	= &spi3_clk.common.hw,
+		[CLK_BUS_SPI3]	= &bus_spi3_clk.common.hw,
+		[CLK_SPI4]	= &spi4_clk.common.hw,
+		[CLK_BUS_SPI4]	= &bus_spi4_clk.common.hw,
 		[CLK_GPADC]	= &gpadc_clk.common.hw,
 		[CLK_BUS_GPADC]	= &bus_gpadc_clk.common.hw,
 		[CLK_BUS_THS]	= &bus_ths_clk.common.hw,
@@ -190,6 +220,11 @@ static struct ccu_reset_map sun60i_a733_ccu_resets[] = {
 	[RST_BUS_I2C10]	= { 0xe80, BIT(26) },
 	[RST_BUS_I2C11]	= { 0xe80, BIT(27) },
 	[RST_BUS_I2C12]	= { 0xe80, BIT(28) },
+	[RST_BUS_SPI0]	= { 0x96c, BIT(16) },
+	[RST_BUS_SPI1]	= { 0x96c, BIT(17) },
+	[RST_BUS_SPI2]	= { 0x96c, BIT(18) },
+	[RST_BUS_SPI3]	= { 0x96c, BIT(20) },
+	[RST_BUS_SPI4]	= { 0x96c, BIT(21) },
 	[RST_BUS_GPADC]	= { 0x9ec, BIT(16) },
 	[RST_BUS_THS]	= { 0x9fc, BIT(16) },
 	[RST_USB_PHY0]	= { 0xa8c, BIT(16) },
diff --git a/include/dt-bindings/clock/sun60i-a733-ccu.h b/include/dt-bindings/clock/sun60i-a733-ccu.h
index bcba4a119fe9..daa0f6cdcff3 100644
--- a/include/dt-bindings/clock/sun60i-a733-ccu.h
+++ b/include/dt-bindings/clock/sun60i-a733-ccu.h
@@ -29,6 +29,16 @@
 #define CLK_BUS_I2C10		171
 #define CLK_BUS_I2C11		172
 #define CLK_BUS_I2C12		173
+#define CLK_SPI0		174
+#define CLK_BUS_SPI0		175
+#define CLK_SPI1		176
+#define CLK_BUS_SPI1		177
+#define CLK_SPI2		178
+#define CLK_BUS_SPI2		179
+#define CLK_SPI3		182
+#define CLK_BUS_SPI3		183
+#define CLK_SPI4		184
+#define CLK_BUS_SPI4		185
 #define CLK_GPADC		186
 #define CLK_BUS_GPADC		187
 #define CLK_BUS_THS		188
diff --git a/include/dt-bindings/reset/sun60i-a733-ccu.h b/include/dt-bindings/reset/sun60i-a733-ccu.h
index 0a642aa4bad5..b79e6e76ad3e 100644
--- a/include/dt-bindings/reset/sun60i-a733-ccu.h
+++ b/include/dt-bindings/reset/sun60i-a733-ccu.h
@@ -25,6 +25,11 @@
 #define RST_BUS_I2C10		58
 #define RST_BUS_I2C11		59
 #define RST_BUS_I2C12		60
+#define RST_BUS_SPI0		61
+#define RST_BUS_SPI1		62
+#define RST_BUS_SPI2		63
+#define RST_BUS_SPI3		65
+#define RST_BUS_SPI4		66
 #define RST_BUS_GPADC		67
 #define RST_BUS_THS		68
 #define RST_USB_PHY0		81
-- 
