From d3b46f79b5832d1265399b7fdf63a3c2c37dab4d Mon Sep 17 00:00:00 2001
From: Enzo <enzo@homelab.local>
Date: Thu, 4 Jun 2026 19:41:13 -0400
Subject: [PATCH 2/3] clk: sunxi-ng: add A733 DMA clocks

---
 drivers/clk/sunxi-ng/ccu-sun60i-a733.c      | 7 +++++++
 include/dt-bindings/clock/sun60i-a733-ccu.h | 2 ++
 include/dt-bindings/reset/sun60i-a733-ccu.h | 1 +
 3 files changed, 10 insertions(+)

diff --git a/drivers/clk/sunxi-ng/ccu-sun60i-a733.c b/drivers/clk/sunxi-ng/ccu-sun60i-a733.c
index ef6ca0a1e4e0..a648b47fa730 100644
--- a/drivers/clk/sunxi-ng/ccu-sun60i-a733.c
+++ b/drivers/clk/sunxi-ng/ccu-sun60i-a733.c
@@ -29,6 +29,8 @@ static const struct clk_parent_data hosc[] = {
 
 static SUNXI_CCU_GATE_DATA(mmc0_clk, "mmc0", hosc, 0xd00, BIT(31), 0);
 static SUNXI_CCU_GATE_DATA(bus_mmc0_clk, "bus-mmc0", hosc, 0xd0c, BIT(0), 0);
+static SUNXI_CCU_GATE_DATA(mbus_dma_clk, "mbus-dma", hosc, 0x804, BIT(0), 0);
+static SUNXI_CCU_GATE_DATA(bus_dma_clk, "bus-dma", hosc, 0x70c, BIT(0), 0);
 static SUNXI_CCU_GATE_HWS(bus_uart0_clk, "bus-uart0", apb_uart_hws,
 			  0xe00, BIT(0), 0);
 static SUNXI_CCU_GATE_HWS(bus_uart1_clk, "bus-uart1", apb_uart_hws,
@@ -77,6 +79,8 @@ static SUNXI_CCU_GATE_DATA(bus_gmac0_clk, "bus-gmac0", hosc,
 static struct ccu_common *sun60i_a733_ccu_clks[] = {
 	&mmc0_clk.common,
 	&bus_mmc0_clk.common,
+	&mbus_dma_clk.common,
+	&bus_dma_clk.common,
 	&bus_uart0_clk.common,
 	&bus_uart1_clk.common,
 	&bus_uart2_clk.common,
@@ -121,6 +125,8 @@ static struct clk_hw_onecell_data sun60i_a733_hw_clks = {
 		[CLK_APB_UART]	= &apb_uart_clk.hw,
 		[CLK_MMC0]	= &mmc0_clk.common.hw,
 		[CLK_BUS_MMC0]	= &bus_mmc0_clk.common.hw,
+		[CLK_MBUS_DMA]	= &mbus_dma_clk.common.hw,
+		[CLK_BUS_DMA]	= &bus_dma_clk.common.hw,
 		[CLK_BUS_UART0]	= &bus_uart0_clk.common.hw,
 		[CLK_BUS_UART1]	= &bus_uart1_clk.common.hw,
 		[CLK_BUS_UART2]	= &bus_uart2_clk.common.hw,
@@ -163,6 +169,7 @@ static struct clk_hw_onecell_data sun60i_a733_hw_clks = {
 
 static struct ccu_reset_map sun60i_a733_ccu_resets[] = {
 	[RST_BUS_MMC0]	= { 0xd0c, BIT(16) },
+	[RST_BUS_DMA]	= { 0x70c, BIT(16) },
 	[RST_BUS_UART0]	= { 0xe00, BIT(16) },
 	[RST_BUS_UART1]	= { 0xe00, BIT(17) },
 	[RST_BUS_UART2]	= { 0xe00, BIT(18) },
diff --git a/include/dt-bindings/clock/sun60i-a733-ccu.h b/include/dt-bindings/clock/sun60i-a733-ccu.h
index 87944854fabc..bcba4a119fe9 100644
--- a/include/dt-bindings/clock/sun60i-a733-ccu.h
+++ b/include/dt-bindings/clock/sun60i-a733-ccu.h
@@ -7,6 +7,8 @@
 #define CLK_APB_UART		46
 #define CLK_MMC0		143
 #define CLK_BUS_MMC0		144
+#define CLK_MBUS_DMA		97
+#define CLK_BUS_DMA		98
 #define CLK_BUS_UART0		154
 #define CLK_BUS_UART1		155
 #define CLK_BUS_UART2		156
diff --git a/include/dt-bindings/reset/sun60i-a733-ccu.h b/include/dt-bindings/reset/sun60i-a733-ccu.h
index f944ef3195cf..0a642aa4bad5 100644
--- a/include/dt-bindings/reset/sun60i-a733-ccu.h
+++ b/include/dt-bindings/reset/sun60i-a733-ccu.h
@@ -3,6 +3,7 @@
 #ifndef _DT_BINDINGS_RST_SUN60I_A733_CCU_H_
 #define _DT_BINDINGS_RST_SUN60I_A733_CCU_H_
 
+#define RST_BUS_DMA		11
 #define RST_BUS_MMC0		35
 #define RST_BUS_UART0		41
 #define RST_BUS_UART1		42
-- 
2.53.0

