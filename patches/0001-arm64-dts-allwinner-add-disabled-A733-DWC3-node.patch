From 3c7c2f633fd10155879525dcf129729acae792bc Mon Sep 17 00:00:00 2001
From: Enzo <enzo@homelab.local>
Date: Thu, 4 Jun 2026 08:51:24 -0400
Subject: [PATCH] arm64: dts: allwinner: add disabled A733 DWC3 node

Signed-off-by: Enzo <enzo@homelab.local>
---
 arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi | 12 ++++++++++++
 1 file changed, 12 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi b/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
index 40c1733d29dc..92970a25b0b8 100644
--- a/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
@@ -560,6 +560,18 @@ ohci1: usb@4200400 {
 			status = "disabled";
 		};
 
+		usb3: usb@6a00000 {
+			compatible = "snps,dwc3";
+			reg = <0x06a00000 0x100000>;
+			interrupts = <GIC_SPI 155 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&ccu CLK_BUS_USB3>, <&ccu CLK_USB3_REF>,
+				 <&ccu CLK_USB3_SUSPEND>;
+			clock-names = "bus_early", "ref", "suspend";
+			resets = <&ccu RST_BUS_USB3>;
+			dr_mode = "host";
+			status = "disabled";
+		};
+
 		mmc0: mmc@4020000 {
 			compatible = "allwinner,sun60i-a733-mmc",
 				     "allwinner,sun20i-d1-mmc";
-- 
2.53.0

