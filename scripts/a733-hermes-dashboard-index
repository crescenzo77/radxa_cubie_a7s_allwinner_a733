#!/usr/bin/env bash
set -euo pipefail

repo=${A733_HERMES_REPO:-/srv/projects/homelab}
outdir="$repo/task-packets/kernel/hermes-hourly"
json="$outdir/a733-dashboard-index-latest.json"
md="$outdir/a733-dashboard-index-latest.md"
html="$outdir/a733-dashboard-index-latest.html"
state="$outdir/a733-dashboard-index-state.json"
telegram_env=${A733_TELEGRAM_ENV:-/etc/telegram-tasks-bot/bot.env}
report_url=${A733_DASHBOARD_REPORT_URL:-http://192.168.50.225:9181/hermes-hourly/a733-dashboard-index-latest.html}
mkdir -p "$outdir"

python3 - "$repo" "$outdir" "$json" "$md" "$html" "$state" "$telegram_env" "$report_url" "$0" <<'PY'
import datetime as dt
import hashlib
import html
import json
import pathlib
import subprocess
import sys
import urllib.request

repo, outdir, json_path, md_path, html_path, state_path, telegram_env, report_url, script_path = sys.argv[1:]
repo = pathlib.Path(repo)
outdir = pathlib.Path(outdir)
kernel_reports_dir = outdir.parent
hourly_url = "http://192.168.50.225:9181/hermes-hourly"
source_diff_url = "http://192.168.50.225:9181/hermes-source-diff"
stale_after_seconds = 75 * 60

reports = [
    ("safety_audit", "Hermes safety audit", outdir, hourly_url, "a733-hermes-safety-audit-latest"),
    ("blocker_brief", "Patch blocker brief", outdir, hourly_url, "a733-patch-blocker-brief-latest"),
    ("workflow_status", "Workflow status", outdir, hourly_url, "a733-workflow-status-latest"),
    ("public_patch_readiness", "Public patch readiness", outdir, hourly_url, "a733-public-patch-readiness-latest"),
    ("repo_drift", "Repo drift", outdir, hourly_url, "a733-repo-drift-latest"),
    ("repo_sync_approval", "Repo sync approval brief", outdir, hourly_url, "a733-repo-sync-approval-brief-latest"),
    ("h149_approval", "H149 approval brief", outdir, hourly_url, "a733-h149-approval-brief-latest"),
    ("model_health", "Model endpoint health", outdir, hourly_url, "a733-model-health-latest"),
    ("public_source", "Public source monitor", outdir, hourly_url, "a733-public-source-latest"),
    ("radxa_provenance", "Radxa provenance audit", kernel_reports_dir / "hermes-source-diff", source_diff_url, "a733-radxa-provenance-audit-latest"),
]

now_dt = dt.datetime.now(dt.timezone.utc)
now = now_dt.strftime("%Y-%m-%dT%H:%M:%SZ")

def load_json(report_dir, stem):
    path = report_dir / f"{stem}.json"
    if not path.exists():
        return {}, "missing"
    try:
        return json.loads(path.read_text(encoding="utf-8")), "ok"
    except Exception as exc:
        return {"load_error": str(exc)}, "error"

def run(cmd, cwd=None):
    try:
        proc = subprocess.run(cmd, cwd=cwd, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, timeout=10)
        return proc.stdout.strip()
    except Exception as exc:
        return f"error: {exc}"

def sha256(path):
    p = pathlib.Path(path)
    if not p.exists():
        return "missing"
    return hashlib.sha256(p.read_bytes()).hexdigest()

def summarize_status(status_text):
    lines = [line for line in status_text.splitlines() if line.strip()]
    branch = lines[0] if lines else "unknown"
    modified = sum(1 for line in lines[1:] if line.startswith(" M") or line.startswith("M "))
    untracked = sum(1 for line in lines[1:] if line.startswith("??"))
    other = max(0, len(lines) - 1 - modified - untracked)
    return {
        "branch": branch,
        "modified": modified,
        "untracked": untracked,
        "other": other,
    }

def read_env(path):
    env = {}
    p = pathlib.Path(path)
    if not p.exists():
        return env
    for line in p.read_text(encoding="utf-8", errors="replace").splitlines():
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        env[key.strip()] = value.strip().strip('"').strip("'")
    return env

def telegram(text):
    cfg = read_env(telegram_env)
    token = cfg.get("TELEGRAM_BOT_TOKEN")
    chat = cfg.get("TASK_NOTIFY_USER_ID") or cfg.get("CLEAN_TASK_USER_ID")
    if not token or not chat:
        return "telegram env missing"
    req = urllib.request.Request(
        f"https://api.telegram.org/bot{token}/sendMessage",
        data=json.dumps({"chat_id": chat, "text": text, "disable_web_page_preview": False}).encode(),
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    urllib.request.urlopen(req, timeout=15).read()
    return "sent"

def age_seconds(path):
    if not path.exists():
        return None
    return max(0, int((now_dt - dt.datetime.fromtimestamp(path.stat().st_mtime, dt.timezone.utc)).total_seconds()))

def age_text(path):
    age = age_seconds(path)
    if age is None:
        return "missing"
    if age < 90:
        return f"{age}s"
    minutes = age // 60
    if minutes < 120:
        return f"{minutes}m"
    return f"{minutes // 60}h{minutes % 60:02d}m"

rows = []
for key, title, report_dir, url_base, stem in reports:
    data, state = load_json(report_dir, stem)
    md_file = report_dir / f"{stem}.md"
    html_file = report_dir / f"{stem}.html"
    age_s = age_seconds(md_file)
    rows.append({
        "key": key,
        "title": title,
        "report_dir": str(report_dir),
        "stem": stem,
        "state": state,
        "generated_at": data.get("generated_at", "unknown"),
        "age": age_text(md_file),
        "age_seconds": age_s,
        "stale": age_s is None or age_s > stale_after_seconds,
        "md_url": f"{url_base}/{stem}.md",
        "html_url": f"{url_base}/{stem}.html",
        "json_url": f"{url_base}/{stem}.json",
        "data": data,
    })

blocker_data = next((r["data"] for r in rows if r["key"] == "blocker_brief"), {})
workflow_data = next((r["data"] for r in rows if r["key"] == "workflow_status"), {})
health_data = next((r["data"] for r in rows if r["key"] == "model_health"), {})
safety_data = next((r["data"] for r in rows if r["key"] == "safety_audit"), {})
radxa_data = next((r["data"] for r in rows if r["key"] == "radxa_provenance"), {})

blockers = blocker_data.get("blockers") or []
queue_head = blocker_data.get("queue_head") or {}
model_failures = blocker_data.get("model_failures") or []
if not model_failures:
    model_failures = [c.get("name", "unknown") for c in health_data.get("checks", []) if not c.get("ok")]
safety_status = safety_data.get("status", "unknown")
radxa_kernel_source = {
    "found_exact_radxa_kernel_source": radxa_data.get("found_exact_radxa_kernel_source"),
    "question": radxa_data.get("question", "unknown"),
    "recommendation": radxa_data.get("recommendation", "unknown"),
}
report_findings = []
for row in rows:
    if row["state"] != "ok":
        report_findings.append(f"{row['title']} report state is {row['state']}")
    if row["stale"]:
        report_findings.append(f"{row['title']} report is stale or missing; age={row['age']}")
if safety_status != "ok":
    report_findings.append(f"Hermes safety audit status is {safety_status}")
dashboard_status = "ok" if not report_findings else "attention"
repo_status = run(["git", "status", "--short", "--branch"], cwd=repo)
provenance = {
    "repo": str(repo),
    "repo_head": run(["git", "rev-parse", "--short=12", "HEAD"], cwd=repo),
    "repo_status": repo_status,
    "repo_status_summary": summarize_status(repo_status),
    "script_path": script_path,
    "script_sha256": sha256(script_path),
}

next_safe_actions = [
    "Keep Hermes monitor-only until the operator approves a repo sync path or H149 live hardware work.",
    "Use the repo sync approval brief before treating ThinkCentre patch-readiness output as authoritative.",
    "Do not run H149 unless the explicit approval text in the H149 approval brief is provided.",
]

doc = {
    "generated_at": now,
    "dashboard_status": dashboard_status,
    "base_url": hourly_url,
    "queue_head": queue_head,
    "blockers": blockers,
    "model_failures": model_failures,
    "safety_status": safety_status,
    "radxa_kernel_source": radxa_kernel_source,
    "report_findings": report_findings,
    "stale_after_seconds": stale_after_seconds,
    "provenance": provenance,
    "next_safe_actions": next_safe_actions,
    "workflow_queue_head": workflow_data.get("queue_head"),
    "reports": [{k: v for k, v in r.items() if k != "data"} for r in rows],
    "not_authorized": [
        "live hardware/runtime sweep",
        "Cubie reboot or power-cycle",
        "repo sync, pull, push, reset, or branch promotion",
        "patch regeneration or b4 send",
        "email or maintainer-list action",
    ],
}
pathlib.Path(json_path).write_text(json.dumps(doc, indent=2) + "\n", encoding="utf-8")

lines = [
    "# A733 Hermes Dashboard",
    "",
    f"Generated: `{now}`",
    f"Dashboard status: `{dashboard_status}`",
    "",
    "## Current Queue Head",
    "",
    f"- ID: `{queue_head.get('id', 'unknown')}`",
    f"- Status: `{queue_head.get('status', workflow_data.get('queue_head', 'unknown'))}`",
    f"- Title: `{queue_head.get('title', 'unknown')}`",
    "",
    "## Active Blockers",
    "",
]
lines += [f"- {b}" for b in blockers] or ["- none reported by blocker brief"]
lines += ["", "## Report Health", ""]
lines += [f"- {f}" for f in report_findings] or [f"- all reports fresh within `{stale_after_seconds}` seconds"]
lines += ["", "## Next Safe Actions", ""]
lines += [f"- {a}" for a in next_safe_actions]
lines += ["", "## Hermes Safety", "", f"- Scheduler audit status: `{safety_status}`"]
lines += [
    "",
    "## Radxa Kernel Source",
    "",
    f"- Exact Radxa `5.15.147-21-a733` source proven: `{radxa_kernel_source['found_exact_radxa_kernel_source']}`",
    f"- Recommendation: {radxa_kernel_source['recommendation']}",
]
lines += [
    "",
    "## Provenance",
    "",
    f"- Homelab repo: `{provenance['repo']}`",
    f"- Homelab repo HEAD: `{provenance['repo_head']}`",
    f"- Dashboard script: `{provenance['script_path']}`",
    f"- Dashboard script SHA-256: `{provenance['script_sha256']}`",
    f"- Repo branch: `{provenance['repo_status_summary']['branch']}`",
    f"- Repo dirty counts: modified `{provenance['repo_status_summary']['modified']}`, untracked `{provenance['repo_status_summary']['untracked']}`, other `{provenance['repo_status_summary']['other']}`",
]
lines += ["", "## Model Endpoint Failures", ""]
lines += [f"- `{m}`" for m in model_failures] or ["- none reported"]
lines += ["", "## Reports", ""]
lines += ["| Report | State | Fresh | Generated | Age | Links |", "|---|---:|---:|---:|---:|---|"]
for row in rows:
    links = f"[html]({row['html_url']}) [md]({row['md_url']}) [json]({row['json_url']})"
    fresh = "no" if row["stale"] else "yes"
    lines.append(f"| {row['title']} | `{row['state']}` | `{fresh}` | `{row['generated_at']}` | `{row['age']}` | {links} |")
lines += [
    "",
    "## Not Authorized",
    "",
]
lines += [f"- {x}" for x in doc["not_authorized"]]
lines += ["", "This dashboard is read-only. It summarizes existing Hermes reports and does not approve or perform work.", ""]
pathlib.Path(md_path).write_text("\n".join(lines), encoding="utf-8")

escaped = html.escape(pathlib.Path(md_path).read_text(encoding="utf-8"))
pathlib.Path(html_path).write_text(
    "<!doctype html><meta charset='utf-8'><title>A733 Hermes Dashboard</title>"
    "<style>body{font-family:system-ui,sans-serif;max-width:1150px;margin:2rem auto;line-height:1.45}"
    "pre{white-space:pre-wrap;background:#f6f8fa;padding:1rem;border:1px solid #ddd}</style>"
    f"<pre>{escaped}</pre>\n",
    encoding="utf-8",
)

new_state = {
    "dashboard_status": dashboard_status,
    "report_findings": report_findings,
    "safety_status": safety_status,
}
state_file = pathlib.Path(state_path)
old_state = {}
if state_file.exists():
    try:
        old_state = json.loads(state_file.read_text(encoding="utf-8"))
    except Exception:
        old_state = {}
state_file.write_text(json.dumps({**new_state, "updated_at": now}, indent=2) + "\n", encoding="utf-8")
if old_state and (
    old_state.get("dashboard_status") != dashboard_status
    or old_state.get("report_findings") != report_findings
    or old_state.get("safety_status") != safety_status
):
    finding_text = "; ".join(report_findings) if report_findings else "none"
    telegram(
        "A733 Hermes dashboard status changed\n"
        f"Dashboard: {dashboard_status}\n"
        f"Safety: {safety_status}\n"
        f"Findings: {finding_text}\n"
        f"Report: {report_url}"
    )
print(f"wrote {md_path}")
PY
