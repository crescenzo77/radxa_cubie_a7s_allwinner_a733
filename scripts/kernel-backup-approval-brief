#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
public_repo="${KERNEL_PUBLIC_REPO:-/Users/enzo/projects/Home Lab/cubie-a7s-armbian}"

echo "# Kernel Backup Approval Brief"
echo
echo "Private workflow backup posture:"
echo
echo '```text'
"${repo_root}/scripts/kernel-workflow-status" --workflow-backup-status
echo '```'
echo
echo "Workflow dirty status:"
echo
echo '```text'
"${repo_root}/scripts/kernel-workflow-status" --workflow-dirty-status
echo '```'
echo
echo "Private workflow remotes:"
echo
echo '```text'
git -C "${repo_root}" remote -v || true
echo '```'
echo
echo "Public kernel remotes:"
echo
echo '```text'
git -C "${public_repo}" remote -v || true
echo '```'
echo
private_github_backed="$("${repo_root}/scripts/kernel-workflow-status" --workflow-backup-status | awk -F= '/^private_github_backed=/{print $2}')"
public_github_backed="$("${repo_root}/scripts/kernel-workflow-status" --workflow-backup-status | awk -F= '/^public_github_backed=/{print $2}')"

if [[ "${private_github_backed}" == "yes" ]]; then
  cat <<'BRIEF'
The private workflow repo is backed up to both its configured local origin and
its configured private GitHub backup remote. Do not add another private GitHub
remote unless the human operator explicitly changes the destination.
BRIEF
else
  cat <<'BRIEF'
The private workflow repo is currently backed up to its configured local origin,
but not to a matching GitHub backup remote. Do not add a GitHub remote or push
private workflow material to GitHub without explicit human approval of the
destination URL and expected visibility.

Approval needed before Codex can make the private workflow backup fully match
the standing stopping-point goal:

- remote name, default `github`
- GitHub URL, for example `git@github.com:OWNER/PRIVATE-REPO.git`
- visibility expectation, normally `private`

After that approval, the intended shape is:

```sh
git remote add github APPROVED_GITHUB_URL
git push github main
```
BRIEF
fi

echo
if [[ "${public_github_backed}" == "yes" ]]; then
  cat <<'BRIEF'
The public kernel-facing repo is also backed up to its public GitHub remote.
BRIEF
else
  cat <<'BRIEF'
The public kernel-facing repo is not backed up to its public GitHub remote.
During A733 local-work-only mode, this is a public-push gate: do not push it
unless the human operator explicitly reopens that public backup action.
BRIEF
fi
