#!/usr/bin/env bash
set -u

ok=0
fail=0

check_url() {
  local name="$1"
  local url="$2"

  if curl -fsS --max-time 5 "$url" >/tmp/routing-health.$$ 2>/tmp/routing-health.err.$$; then
    printf '[OK]   %s\n' "$name"
    ok=$((ok + 1))
  else
    printf '[FAIL] %s\n' "$name"
    printf '       %s\n' "$url"
    sed 's/^/       /' /tmp/routing-health.err.$$ 2>/dev/null || true
    fail=$((fail + 1))
  fi

  rm -f /tmp/routing-health.$$ /tmp/routing-health.err.$$
}

echo 'Homelab routing health'
echo

check_url 'LiteLLM models on thinkcentre' 'http://192.168.50.225:4000/v1/models'
check_url 'AMD 3090 local coder models' 'http://192.168.50.252:8083/v1/models'
check_url 'AMD 7900 XT backup models' 'http://192.168.50.252:8084/v1/models'
check_url 'Strix reasoning models' 'http://192.168.50.11:8081/v1/models'
check_url 'Strix coder testbed models' 'http://192.168.50.11:8082/v1/models'

echo
printf 'Summary: %s ok, %s failed\n' "$ok" "$fail"

if [ "$fail" -gt 0 ]; then
  exit 1
fi
