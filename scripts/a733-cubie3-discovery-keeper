#!/usr/bin/env python3
import json
import os
import pathlib
import subprocess
import time


REPO = pathlib.Path(os.environ.get("A733_HERMES_REPO", "/srv/projects/homelab"))
STRIX = os.environ.get("A733_HERMES_STRIX", "strix")


def run(cmd, timeout=60):
    return subprocess.run(
        cmd,
        shell=True,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        timeout=timeout,
    )


def ssh_strix(script, timeout=60):
    quoted = script.replace("'", "'\"'\"'")
    return run(f"ssh -o BatchMode=yes -o ConnectTimeout=10 {STRIX} '{quoted}'", timeout=timeout)


def main():
    rc, out = ssh_strix(
        r'''
set -eu
cd /srv/projects/homelab
mkdir -p logs task-packets/kernel/results
if pgrep -f 'a733-idmac-bruteforce-lab full-auto' >/dev/null; then
  echo 'cubie3-discovery=already-running'
  exit 0
fi
skip=$(
python3 - <<'PY'
import glob, json
items = []
seen = set()
for path in glob.glob("task-packets/kernel/results/a733-idmac-bruteforce-*.json"):
    try:
        doc = json.load(open(path))
    except Exception:
        continue
    cand = doc.get("winning_candidate") or {}
    if doc.get("status") != "pass" or not cand:
        continue
    key = f"{cand.get('kind')}:{cand.get('addr')}:{cand.get('bit')}"
    if key not in seen:
        seen.add(key)
        items.append(key)
print(",".join(items))
PY
)
log=logs/a733-idmac-bruteforce-$(date -u +%Y%m%dT%H%M%SZ).log
export A733_BF_REUSE_ARTIFACT=1
export A733_BF_SKIP_CANDIDATES="$skip"
nohup scripts/a733-idmac-bruteforce-lab full-auto > "$log" 2>&1 < /dev/null &
echo "cubie3-discovery=started pid=$! log=$log skip=$skip"
''',
        timeout=60,
    )
    print(out)
    raise SystemExit(rc)


if __name__ == "__main__":
    main()
