#!/usr/bin/env bash
set -euo pipefail

amd_host="${AMD_VALIDATION_HOST:-192.168.50.252}"
target_host="${CUBIE_STAGE_TARGET:-192.168.50.95}"
excluded_targets="${CUBIE_STAGE_EXCLUDED_TARGETS:-192.168.50.65}"
show_help=0
case "${1:-}" in
  -h|--help)
    show_help=1
    ;;
  "")
    ;;
  *)
    target_host="$1"
    ;;
esac
target_user="${CUBIE_SSH_USER:-codex}"
target_identity="${CUBIE_SSH_IDENTITY:-${HOME}/.ssh/id_ed25519}"
artifact_dir="${A733_BOOT_ARTIFACT_DIR:-/srv/projects/kernel-work/outgoing/a733-v4-abc8d07b0a63-20260606T152409Z}"
artifact_name="$(basename "${artifact_dir}")"
remote_stage="${CUBIE_REMOTE_STAGE:-kernel-boot-artifacts/${artifact_name}}"
install_dir="${CUBIE_BOOT_INSTALL_DIR:-/boot/mainline-a733-v4-abc8d07b0a63}"
label="${CUBIE_EXTLINUX_LABEL:-a733-v4-abc8d07b0a63-uart-proof}"
menu_label="${CUBIE_EXTLINUX_MENU_LABEL:-A733 v4 public candidate abc8d07b0a63 UART proof}"
bootargs_extra="${CUBIE_EXTLINUX_EXTRA_ARGS:-drm_debug=1}"
append_override="${CUBIE_EXTLINUX_APPEND_OVERRIDE:-}"

image_sha="b4584f230d436235fb3776a102546e05d8fac1d93206d25f3566aedad7e60b7d"
dtb_sha="9ac58728715b7999bda4fe579bb00a4c9da7f123c7d0fb1bf9e4664cd85a0e44"
config_sha="9273c649385ba95c589c9f4867a77addebb7bf39ac7a7bb3d655d4980eb7ca87"
manifest_sha="1c0ba61cc7f13ef4488cb7ede4db5d9b653b7352623d2ae29375cbee84ff7f09"
capture_label="${CUBIE_CAPTURE_LABEL:-${artifact_name}-boot}"

usage() {
  cat <<USAGE
Usage: scripts/cubie-stage-boot-artifacts [TARGET_IP]

Copies the exact A733 v4 Image/DTB/config/manifest from AMD into the target
board user's home directory and writes an installer script. The lab default is
the passwordless `codex` automation user on each Cubie.

Defaults:
  AMD_VALIDATION_HOST=${amd_host}
  TARGET_IP=${target_host}
  CUBIE_SSH_USER=${target_user}
  CUBIE_SSH_IDENTITY=${target_identity}
  A733_BOOT_ARTIFACT_DIR=${artifact_dir}
  CUBIE_REMOTE_STAGE=${remote_stage}
  CUBIE_STAGE_EXCLUDED_TARGETS=${excluded_targets}
  CUBIE_EXTLINUX_MENU_LABEL=${menu_label}
  CUBIE_EXTLINUX_EXTRA_ARGS=${bootargs_extra}
  CUBIE_EXTLINUX_APPEND_OVERRIDE=${append_override}

This script does not write /boot, change boot defaults, power-cycle, or reboot.
USAGE
}

if [ "${show_help}" -eq 1 ]; then
  usage
  exit 0
fi

case "${target_host}" in
  192.168.50.*) ;;
  *)
    echo "refusing non-lab target IP: ${target_host}" >&2
    exit 2
    ;;
esac

IFS=',' read -r -a excluded_target_list <<<"${excluded_targets}"
for excluded_target in "${excluded_target_list[@]}"; do
  excluded_target="${excluded_target//[[:space:]]/}"
  if [ -n "${excluded_target}" ] && [ "${target_host}" = "${excluded_target}" ]; then
    echo "refusing excluded kernel-work target: ${target_host}" >&2
    exit 2
  fi
done

require_match() {
  local name="$1"
  local value="$2"
  local pattern="$3"
  if [[ ! "${value}" =~ ${pattern} ]]; then
    echo "refusing unsafe ${name}: ${value}" >&2
    exit 2
  fi
}

require_match artifact_name "${artifact_name}" '^[A-Za-z0-9_.-]+$'
require_match remote_stage "${remote_stage}" '^kernel-boot-artifacts/[A-Za-z0-9_.-]+$'
require_match install_dir "${install_dir}" '^/boot/mainline-a733-[A-Za-z0-9_.-]+$'
require_match label "${label}" '^[A-Za-z0-9_.-]+$'
require_match menu_label "${menu_label}" '^[A-Za-z0-9_.=,:/ -]+$'
require_match capture_label "${capture_label}" '^[A-Za-z0-9_.-]+$'
require_match image_sha "${image_sha}" '^[0-9a-f]{64}$'
require_match dtb_sha "${dtb_sha}" '^[0-9a-f]{64}$'
require_match config_sha "${config_sha}" '^[0-9a-f]{64}$'
require_match manifest_sha "${manifest_sha}" '^[0-9a-f]{64}$'
if [ -n "${bootargs_extra}" ]; then
  require_match bootargs_extra "${bootargs_extra}" '^[A-Za-z0-9_.=,:/-]+( [A-Za-z0-9_.=,:/-]+)*$'
fi
if [ -n "${append_override}" ]; then
  require_match append_override "${append_override}" '^[A-Za-z0-9_.=,:/-]+( [A-Za-z0-9_.=,:/-]+)*$'
fi

required_files=(Image sun60i-a733-cubie-a7s.dtb config manifest.txt)
target_ssh=(
  ssh
  -o BatchMode=yes
  -o ConnectTimeout=8
  -i "${target_identity}"
  "${target_user}@${target_host}"
)

echo "Checking source artifacts on ${amd_host}"
if [ -d "${artifact_dir}" ]; then
  for file in "${required_files[@]}"; do
    test -r "${artifact_dir}/${file}" || {
      echo "missing local source artifact: ${artifact_dir}/${file}" >&2
      exit 1
    }
  done
  source_mode="local"
else
  ssh -o BatchMode=yes -o ConnectTimeout=8 "${amd_host}" bash -s -- "${artifact_dir}" <<'REMOTE_CHECK'
set -euo pipefail
artifact_dir="$1"
for file in Image sun60i-a733-cubie-a7s.dtb config manifest.txt; do
  test -r "${artifact_dir}/${file}" || {
    echo "missing source artifact: ${artifact_dir}/${file}" >&2
    exit 1
  }
done
REMOTE_CHECK
  source_mode="ssh"
fi

echo "Checking target ${target_host}"
"${target_ssh[@]}" \
  'printf "hostname="; hostname; printf "\narch="; uname -m; if [ -r /proc/device-tree/model ]; then printf "\nmodel="; tr "\000" "\n" </proc/device-tree/model; fi'

echo "Creating remote staging directory: ${remote_stage}"
"${target_ssh[@]}" \
  "mkdir -p '${remote_stage}'"

echo "Copying artifacts from ${amd_host}:${artifact_dir}"
if [ "${source_mode}" = "local" ]; then
  tar -C "${artifact_dir}" -cf - "${required_files[@]}"
else
  ssh -o BatchMode=yes -o ConnectTimeout=8 "${amd_host}" \
    "cd '${artifact_dir}' && tar -cf - ${required_files[*]}"
fi |
  "${target_ssh[@]}" \
    "tar -C '${remote_stage}' -xf -"

echo "Writing checksum file"
"${target_ssh[@]}" \
  "cat > '${remote_stage}/SHA256SUMS'" <<EOF
${image_sha}  Image
${dtb_sha}  sun60i-a733-cubie-a7s.dtb
${config_sha}  config
${manifest_sha}  manifest.txt
EOF

echo "Writing staging metadata"
"${target_ssh[@]}" \
  "cat > '${remote_stage}/install-metadata.env'" <<EOF
ARTIFACT_NAME=${artifact_name}
REMOTE_STAGE=${remote_stage}
INSTALL_DIR=${install_dir}
EXTLINUX_LABEL=${label}
EXTLINUX_MENU_LABEL=${menu_label}
CAPTURE_LABEL=${capture_label}
EXTLINUX_EXTRA_ARGS=${bootargs_extra}
EXTLINUX_APPEND_OVERRIDE=${append_override}
IMAGE_SHA=${image_sha}
DTB_SHA=${dtb_sha}
CONFIG_SHA=${config_sha}
MANIFEST_SHA=${manifest_sha}
EOF

echo "Writing root-required installer"
"${target_ssh[@]}" \
  "cat > '${remote_stage}/install-extlinux-entry.sh'" <<EOF
#!/usr/bin/env bash
set -euo pipefail

stage_dir="\$(cd "\$(dirname "\${BASH_SOURCE[0]}")" && pwd)"
install_dir="${install_dir}"
label="${label}"
menu_label="${menu_label}"
bootargs_extra="${bootargs_extra}"
append_override="${append_override}"
extlinux="/boot/extlinux/extlinux.conf"

cd "\${stage_dir}"
sha256sum -c SHA256SUMS

if [ ! -f "\${extlinux}" ]; then
  echo "missing extlinux config: \${extlinux}" >&2
  exit 1
fi

sudo_cmd=(sudo)
if [ "\$(id -u)" -eq 0 ]; then
  sudo_cmd=()
fi

backup="\${extlinux}.pre-\${label}-\$(date -u +%Y%m%dT%H%M%SZ)"
root_arg="\$(tr ' ' '\\n' </proc/cmdline | awk '/^root=/{ print; exit }')"
if [ -z "\${append_override}" ] && [ -z "\${root_arg}" ]; then
  echo "current /proc/cmdline has no root= argument; refusing to guess" >&2
  exit 1
fi
if [ -n "\${append_override}" ]; then
  append_line="\${append_override}"
else
  append_line="console=ttyS0,115200n8 earlycon=uart8250,mmio32,0x02500000 loglevel=8 ignore_loglevel \${bootargs_extra} \${root_arg} rootwait rw"
fi

tmp="\$(mktemp)"
cleanup() {
  rm -f "\${tmp}"
}
trap cleanup EXIT

cp "\${extlinux}" "\${tmp}"
if grep -q "^label \${label}\$" "\${tmp}"; then
  echo "label already exists in \${extlinux}: \${label}" >&2
  exit 1
fi

cat >>"\${tmp}" <<ENTRY

label \${label}
	menu label \${menu_label}
	linux ${install_dir}/Image
	fdt ${install_dir}/sun60i-a733-cubie-a7s.dtb
	append \${append_line}
ENTRY

"\${sudo_cmd[@]}" install -d -m 0755 "\${install_dir}"
"\${sudo_cmd[@]}" install -m 0644 Image "\${install_dir}/Image"
"\${sudo_cmd[@]}" install -m 0644 sun60i-a733-cubie-a7s.dtb "\${install_dir}/sun60i-a733-cubie-a7s.dtb"
"\${sudo_cmd[@]}" install -m 0644 config "\${install_dir}/config"
"\${sudo_cmd[@]}" install -m 0644 manifest.txt "\${install_dir}/manifest.txt"
"\${sudo_cmd[@]}" install -m 0644 install-metadata.env "\${install_dir}/install-metadata.env"
"\${sudo_cmd[@]}" install -m 0644 SHA256SUMS "\${install_dir}/SHA256SUMS"
sync
if [ "\${#sudo_cmd[@]}" -eq 0 ]; then
  (cd "\${install_dir}" && sha256sum -c SHA256SUMS)
else
  "\${sudo_cmd[@]}" bash -c 'cd "\$1" && sha256sum -c SHA256SUMS' bash "\${install_dir}"
fi
"\${sudo_cmd[@]}" cp -a "\${extlinux}" "\${backup}"
"\${sudo_cmd[@]}" install -m 0644 "\${tmp}" "\${extlinux}"
sync

echo "Installed non-default extlinux label: \${label}"
echo "Backup: \${backup}"
echo "Next: run UART capture, reboot manually, and choose label \${label} in U-Boot."
EOF

"${target_ssh[@]}" \
  "chmod +x '${remote_stage}/install-extlinux-entry.sh' && cd '${remote_stage}' && sha256sum -c SHA256SUMS"

cat <<SUMMARY

Staged exact A733 v4 artifacts on ${target_host}:${remote_stage}

No /boot files were changed. No reboot was requested.

Root install step on the board:
  cd ${remote_stage}
  sudo -n ./install-extlinux-entry.sh

Then from this repo, start the interactive UART boot session before selecting the boot entry:
  scripts/cubie-uart-interactive-boot-session ${capture_label}

Select this non-default U-Boot label over UART:
  ${label}

Temporary bootargs on this label:
  ${append_override:-${bootargs_extra}}
SUMMARY
