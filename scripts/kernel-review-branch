#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: scripts/kernel-review-branch --repo PATH --source REF --branch NAME

Creates or updates a local review branch at SOURCE. This helper does not rebase,
squash, push, or send mail. Use it as a safe branch marker before b4 prep.
USAGE
}

repo=
source=
branch=

while [ "$#" -gt 0 ]; do
  case "$1" in
    --repo) repo="${2:?}"; shift 2 ;;
    --source) source="${2:?}"; shift 2 ;;
    --branch) branch="${2:?}"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "unknown argument: $1" >&2; usage >&2; exit 2 ;;
  esac
done

[ -n "$repo" ] || { echo "--repo is required" >&2; exit 2; }
[ -n "$source" ] || { echo "--source is required" >&2; exit 2; }
[ -n "$branch" ] || { echo "--branch is required" >&2; exit 2; }
[ -d "$repo/.git" ] || { echo "not a git repo: $repo" >&2; exit 2; }

git -C "$repo" rev-parse --verify "$source^{commit}" >/dev/null
git -C "$repo" branch -f "$branch" "$source"
echo "review_branch=$branch"
echo "head=$(git -C "$repo" rev-parse "$branch")"
