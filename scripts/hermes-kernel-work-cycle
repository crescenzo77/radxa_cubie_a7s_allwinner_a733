#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
hermes_bin="${HERMES_BIN:-/home/enzo/.local/bin/hermes}"
prompt_file="${HERMES_KERNEL_PROMPT:-${repo_root}/runbooks/hermes-kernel-work-prompt.md}"
timeout_seconds="${HERMES_KERNEL_TIMEOUT:-900}"
notify_enabled="${HERMES_KERNEL_NOTIFY:-0}"
notify_target="${HERMES_KERNEL_NOTIFY_TARGET:-telegram}"
cubie_access_tier="${HERMES_CUBIE_ACCESS_TIER:-partial}"
toolsets="${HERMES_KERNEL_TOOLSETS:-terminal,file,code_execution,messaging}"
provider="${HERMES_KERNEL_PROVIDER:-openwebui-hub}"
model="${HERMES_KERNEL_MODEL:-Strix Qwen3.6 27B Dense ROCmFP4-MTP headQ6 GGUF rocmfp4-llama ROCm+Vulkan ctx256k self-spec reasoning-off coding}"
stamp="$(date -u +%Y%m%dT%H%M%SZ)"
work_dir="${HERMES_KERNEL_WORK_DIR:-${repo_root}/task-packets/kernel/hermes-work}"
log_file="${work_dir}/${stamp}-hermes-kernel-work.log"
report_file="${work_dir}/${stamp}-hermes-kernel-work.md"
prompt_snapshot="${work_dir}/${stamp}-hermes-kernel-work.prompt.md"

usage() {
  cat <<USAGE
Usage: scripts/hermes-kernel-work-cycle

Runs one supervised Hermes kernel-work cycle with a timeout and writes both a
raw log and a status report. Cubie hardware access is governed by
HERMES_CUBIE_ACCESS_TIER. The wrapper does not grant Hermes approval to change
services, cron, model routing, remotes, mail submission, or kernel source
commits.

Environment:
  HERMES_BIN=${hermes_bin}
  HERMES_KERNEL_PROMPT=${prompt_file}
  HERMES_KERNEL_TIMEOUT=${timeout_seconds}
  HERMES_KERNEL_WORK_DIR=${work_dir}
  HERMES_KERNEL_NOTIFY=${notify_enabled}
  HERMES_KERNEL_NOTIFY_TARGET=${notify_target}
  HERMES_CUBIE_ACCESS_TIER=${cubie_access_tier}
  HERMES_KERNEL_TOOLSETS=${toolsets}
  HERMES_KERNEL_PROVIDER=${provider}
  HERMES_KERNEL_MODEL=${model}
USAGE
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
esac

test -r "${prompt_file}" || {
  echo "missing prompt file: ${prompt_file}" >&2
  exit 2
}
test -x "${hermes_bin}" || {
  echo "missing executable Hermes binary: ${hermes_bin}" >&2
  exit 2
}
case "${cubie_access_tier}" in
  strict|partial|total) ;;
  *)
    echo "HERMES_CUBIE_ACCESS_TIER must be strict, partial, or total" >&2
    exit 2
    ;;
esac

mkdir -p "${work_dir}"
case "${cubie_access_tier}" in
  strict)
    cubie_access_policy="Cubie access tier: strict

Allowed Cubie actions:
- read-only inventory, SSH reachability checks, UART mapping, UART capture, log pull, and status summaries
- dry-run proof commands and approval/status packet generation

Not allowed in strict tier:
- writing to /boot or staging artifacts
- rebooting, power cycling, changing boot selection, or running live proof that changes board state
- using cubie1 for runtime proof"
    ;;
  partial)
    cubie_access_policy="Cubie access tier: partial

Allowed Cubie actions:
- everything in strict tier
- stage workflow-identified kernel/boot artifacts to the selected Cubie board
- run live UART/runtime proof on cubie2 and cubie3
- reboot cubie2 or cubie3 through documented workflow commands when required for proof
- collect logs, proof packets, and board comparison summaries

Not allowed in partial tier:
- external power cycling
- persistent bootloader default changes outside the proof workflow
- repartitioning, formatting, dd/raw block writes, firmware/SPI/eMMC bootloader writes, or destructive cleanup
- using cubie1 for state-changing proof unless the run is explicitly upgraded to total"
    ;;
  total)
    cubie_access_policy="Cubie access tier: total

Allowed Cubie actions:
- everything in partial tier
- use cubie1, cubie2, and cubie3 for live runtime proof and reproduction, including concurrent per-board read/capture/proof lanes when useful
- reboot Cubies as needed through documented workflow commands
- use documented cubie*-power helpers for recovery power cycles if a board is wedged
- stage workflow-identified kernel/boot artifacts and run recovery/vendor-restore steps documented in the homelab repo

Still not allowed in total tier:
- repartitioning, formatting, dd/raw block writes, firmware/SPI/eMMC bootloader writes, or destructive cleanup
- persistent bootloader default changes outside documented proof/recovery steps
- simultaneous reboot, power-cycle, artifact-staging, or recovery actions on more than one Cubie; serialize state-changing actions and log the board, command, start time, and result
- changing services, cron, model routing, Hermes gateway, Telegram setup, git remotes, pushes, or mail submission"
    ;;
esac
prompt="$(cat "${prompt_file}")

${cubie_access_policy}"
printf '%s\n' "${prompt}" >"${prompt_snapshot}"

set +e
if command -v timeout >/dev/null 2>&1; then
  timeout "${timeout_seconds}" "${hermes_bin}" --provider "${provider}" --model "${model}" --toolsets "${toolsets}" -z "${prompt}" >"${log_file}" 2>&1
  rc=$?
else
  python3 - "${hermes_bin}" "${timeout_seconds}" "${log_file}" "${prompt_snapshot}" "${toolsets}" "${provider}" "${model}" <<'PY'
from __future__ import annotations

import subprocess
import sys
from pathlib import Path

hermes = sys.argv[1]
timeout = int(sys.argv[2])
log = Path(sys.argv[3])
prompt = Path(sys.argv[4]).read_text(encoding="utf-8")
toolsets = sys.argv[5]
provider = sys.argv[6]
model = sys.argv[7]
with log.open("w", encoding="utf-8") as handle:
    try:
        proc = subprocess.run([hermes, "--provider", provider, "--model", model, "--toolsets", toolsets, "-z", prompt], stdout=handle, stderr=subprocess.STDOUT, timeout=timeout, check=False)
        raise SystemExit(proc.returncode)
    except subprocess.TimeoutExpired:
        handle.write("\nTIMEOUT\n")
        raise SystemExit(124)
PY
  rc=$?
fi
set -e

status="completed"
if [ "${rc}" -eq 124 ]; then
  status="timeout"
elif [ "${rc}" -ne 0 ]; then
  status="failed"
fi

{
  echo "# Hermes Kernel Work Cycle"
  echo
  echo "Generated: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
  echo "Status: \`${status}\`"
  echo "Return code: \`${rc}\`"
  echo "Prompt: \`${prompt_file}\`"
  echo "Prompt snapshot: \`${prompt_snapshot}\`"
  echo "Cubie access tier: \`${cubie_access_tier}\`"
  echo "Toolsets: \`${toolsets}\`"
  echo "Provider: \`${provider}\`"
  echo "Model: \`${model}\`"
  echo "Log: \`${log_file}\`"
  echo
  echo "## Output"
  echo
  echo '```text'
  sed -n '1,240p' "${log_file}"
  echo '```'
} >"${report_file}"

if [ "${notify_enabled}" = "1" ]; then
  notify_message="Hermes kernel work cycle ${status}; rc=${rc}; report=${report_file}; log=${log_file}"
  if ! notify_output="$("${hermes_bin}" send --to "${notify_target}" "${notify_message}" 2>&1)"; then
    echo "warning: Hermes kernel work notification failed: ${notify_output}" >&2
  fi
fi

echo "report=${report_file}"
echo "log=${log_file}"
exit "${rc}"
