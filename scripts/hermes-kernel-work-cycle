#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
hermes_bin="${HERMES_BIN:-/home/enzo/.local/bin/hermes}"
prompt_file="${HERMES_KERNEL_PROMPT:-${repo_root}/runbooks/hermes-kernel-work-prompt.md}"
timeout_seconds="${HERMES_KERNEL_TIMEOUT:-300}"
notify_enabled="${HERMES_KERNEL_NOTIFY:-0}"
notify_target="${HERMES_KERNEL_NOTIFY_TARGET:-telegram}"
cubie_access_tier="${HERMES_CUBIE_ACCESS_TIER:-partial}"
toolsets="${HERMES_KERNEL_TOOLSETS:-terminal,file,code_execution,messaging}"
provider="${HERMES_KERNEL_PROVIDER:-openwebui-hub}"
model="${HERMES_KERNEL_MODEL:-Strix Qwen3.6 27B Dense ROCmFP4-MTP headQ6 GGUF rocmfp4-llama ROCm+Vulkan ctx256k self-spec reasoning-off coding}"
engine="${HERMES_KERNEL_ENGINE:-deterministic}"
stamp="$(date -u +%Y%m%dT%H%M%SZ)"
work_dir="${HERMES_KERNEL_WORK_DIR:-${repo_root}/task-packets/kernel/hermes-work}"
log_file="${work_dir}/${stamp}-hermes-kernel-work.log"
report_file="${work_dir}/${stamp}-hermes-kernel-work.md"
prompt_snapshot="${work_dir}/${stamp}-hermes-kernel-work.prompt.md"
transcript_file="${work_dir}/${stamp}-hermes-kernel-work.transcript.log"

usage() {
  cat <<USAGE
Usage: scripts/hermes-kernel-work-cycle

Runs one supervised Hermes kernel-work cycle with a timeout and writes both a
raw log and a status report. Cubie hardware access is governed by
HERMES_CUBIE_ACCESS_TIER. The wrapper does not grant Hermes approval to change
services, cron, model routing, remotes, mail submission, or kernel source
commits.

Environment:
  HERMES_BIN=${hermes_bin}
  HERMES_KERNEL_PROMPT=${prompt_file}
  HERMES_KERNEL_TIMEOUT=${timeout_seconds}
  HERMES_KERNEL_WORK_DIR=${work_dir}
  HERMES_KERNEL_NOTIFY=${notify_enabled}
  HERMES_KERNEL_NOTIFY_TARGET=${notify_target}
  HERMES_CUBIE_ACCESS_TIER=${cubie_access_tier}
  HERMES_KERNEL_TOOLSETS=${toolsets}
  HERMES_KERNEL_PROVIDER=${provider}
  HERMES_KERNEL_MODEL=${model}
  HERMES_KERNEL_ENGINE=${engine}
USAGE
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
esac

test -r "${prompt_file}" || {
  echo "missing prompt file: ${prompt_file}" >&2
  exit 2
}
test -x "${hermes_bin}" || {
  echo "missing executable Hermes binary: ${hermes_bin}" >&2
  exit 2
}
case "${cubie_access_tier}" in
  strict|partial|total) ;;
  *)
    echo "HERMES_CUBIE_ACCESS_TIER must be strict, partial, or total" >&2
    exit 2
    ;;
esac
case "${engine}" in
  deterministic|agent) ;;
  *)
    echo "HERMES_KERNEL_ENGINE must be deterministic or agent" >&2
    exit 2
    ;;
esac

mkdir -p "${work_dir}"
case "${cubie_access_tier}" in
  strict)
    cubie_access_policy="Cubie access tier: strict

Allowed Cubie actions:
- read-only inventory, SSH reachability checks, UART mapping, UART capture, log pull, and status summaries
- dry-run proof commands and approval/status packet generation

Not allowed in strict tier:
- writing to /boot or staging artifacts
- rebooting, power cycling, changing boot selection, or running live proof that changes board state
- using cubie1 for runtime proof"
    ;;
  partial)
    cubie_access_policy="Cubie access tier: partial

Allowed Cubie actions:
- everything in strict tier
- stage workflow-identified kernel/boot artifacts to the selected Cubie board
- run live UART/runtime proof on cubie2 and cubie3
- reboot cubie2 or cubie3 through documented workflow commands when required for proof
- collect logs, proof packets, and board comparison summaries

Not allowed in partial tier:
- external power cycling
- persistent bootloader default changes outside the proof workflow
- repartitioning, formatting, dd/raw block writes, firmware/SPI/eMMC bootloader writes, or destructive cleanup
- using cubie1 for state-changing proof unless the run is explicitly upgraded to total"
    ;;
  total)
    cubie_access_policy="Cubie access tier: total

Allowed Cubie actions:
- everything in partial tier
- use cubie1, cubie2, and cubie3 for live runtime proof and reproduction, including concurrent per-board read/capture/proof lanes when useful
- reboot Cubies as needed through documented workflow commands
- use documented cubie*-power helpers for recovery power cycles if a board is wedged
- stage workflow-identified kernel/boot artifacts and run recovery/vendor-restore steps documented in the homelab repo

Still not allowed in total tier:
- repartitioning, formatting, dd/raw block writes, firmware/SPI/eMMC bootloader writes, or destructive cleanup
- persistent bootloader default changes outside documented proof/recovery steps
- simultaneous reboot, power-cycle, artifact-staging, or recovery actions on more than one Cubie; serialize state-changing actions and log the board, command, start time, and result
- changing services, cron, model routing, Hermes gateway, Telegram setup, git remotes, pushes, or mail submission"
    ;;
esac
prompt="$(cat "${prompt_file}")

${cubie_access_policy}"
printf '%s\n' "${prompt}" >"${prompt_snapshot}"

run_transcript_cmd() {
  local command="$1"
  {
    printf '$ %s\n' "${command}"
    set +e
    bash -lc "${command}"
    local command_rc=$?
    set -e
    printf '[exit %s]\n\n' "${command_rc}"
    return "${command_rc}"
  } 2>&1 | tee -a "${transcript_file}"
}

if [ "${engine}" = "deterministic" ]; then
  : >"${transcript_file}"
  status_json="${work_dir}/${stamp}-kernel-workflow-status.json"
  patch_json="${work_dir}/${stamp}-kernel-patch-export-status.json"
  post_status_json="${work_dir}/${stamp}-kernel-workflow-status-after.json"

  run_transcript_cmd "pwd" >/dev/null || true
  run_transcript_cmd "scripts/kernel-workflow-env" >/dev/null || true
  run_transcript_cmd "scripts/kernel-workflow-status --json | tee '${status_json}'" >/dev/null || true
  run_transcript_cmd "scripts/kernel-patch-export-status --json | tee '${patch_json}'" >/dev/null || true

  action_label="none"
  action_command=""
  if [ -s "${status_json}" ] && command -v jq >/dev/null 2>&1; then
    runtime_status="$(jq -r '.cubie_runtime_gate.status // ""' "${status_json}" 2>/dev/null || true)"
    runtime_next="$(jq -r '.cubie_runtime_gate.next_command // ""' "${status_json}" 2>/dev/null || true)"
    stack_status="$(jq -r '.a733_prereq_stack.status // ""' "${status_json}" 2>/dev/null || true)"
    stack_findings="$(jq -r '(.a733_prereq_stack.finding_kinds // []) | join(",")' "${status_json}" 2>/dev/null || true)"
    if [ "${runtime_status}" = "boot-artifact-staging-required" ] && [ "${cubie_access_tier}" != "strict" ] && [[ "${runtime_next}" == scripts/cubie-stage-boot-artifacts* ]]; then
      action_label="cubie-runtime-gate-no-reachable-target"
      board_candidates="192.168.50.85 192.168.50.95"
      if [ "${cubie_access_tier}" = "total" ]; then
        board_candidates="192.168.50.85 192.168.50.95"
      fi
      for board_ip in ${board_candidates}; do
        if ssh -o BatchMode=yes -o ConnectTimeout=5 strix \
          "ssh -o BatchMode=yes -o ConnectTimeout=5 -i ~/.ssh/id_ed25519 codex@${board_ip} 'hostname' >/dev/null" \
          >/dev/null 2>&1; then
          action_label="cubie-runtime-gate-strix-reachable-board"
          action_command="ssh strix 'cd /srv/projects/homelab && scripts/cubie-stage-boot-artifacts ${board_ip}'"
          break
        fi
      done
    elif [ "${runtime_status}" = "root-install-required" ] && [ "${cubie_access_tier}" = "total" ]; then
      ready_ip="$(jq -r '.cubie_runtime_gate.staging.rows[]? | select(.ready_for_root_install == true and .sudo_status == "noninteractive-ok") | .ip' "${status_json}" 2>/dev/null | head -1 || true)"
      ready_stage="$(jq -r '.cubie_runtime_gate.staging.rows[]? | select(.ready_for_root_install == true and .sudo_status == "noninteractive-ok") | .stage' "${status_json}" 2>/dev/null | head -1 || true)"
      if [ -n "${ready_ip}" ] && [ -n "${ready_stage}" ]; then
        action_label="cubie-runtime-gate-total-root-install"
        action_command="ssh strix \"ssh -o BatchMode=yes -o ConnectTimeout=8 -i ~/.ssh/id_ed25519 codex@${ready_ip} 'cd ${ready_stage} && sudo -n ./install-extlinux-entry.sh'\""
      else
        action_label="cubie-runtime-gate-root-install-no-noninteractive-target"
      fi
    elif [ "${runtime_status}" = "boot-selection-required" ]; then
      action_label="cubie-runtime-gate-boot-selection-wait-preflight"
      action_command="scripts/kernel-workflow-status --stopping-point-audit"
    elif [ "${stack_status}" = "FAIL" ] && [[ ",${stack_findings}," == *",tree-missing,"* ]]; then
      action_label="sync-missing-prereq-stack"
      action_command="mkdir -p /srv/projects/a733-prereq-stack-current && rsync -a strix:/srv/projects/cubie-a7s-armbian/sources/mainline-linux/ /srv/projects/a733-prereq-stack-current/"
    fi
  fi

  action_rc=0
  if [ -n "${action_command}" ]; then
    run_transcript_cmd "${action_command}" >/dev/null || action_rc=$?
    run_transcript_cmd "scripts/kernel-workflow-status --json | tee '${post_status_json}'" >/dev/null || true
  fi

  status="completed"
  if [ "${action_rc}" -ne 0 ]; then
    status="action-failed"
  fi

  {
    echo "# Hermes Kernel Work Cycle"
    echo
    echo "Generated: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "Status: \`${status}\`"
    echo "Return code: \`0\`"
    echo "Engine: \`${engine}\`"
    echo "Prompt: \`${prompt_file}\`"
    echo "Prompt snapshot: \`${prompt_snapshot}\`"
    echo "Cubie access tier: \`${cubie_access_tier}\`"
    echo "Transcript: \`${transcript_file}\`"
    echo
    echo "## Current Status"
    echo
    if [ -s "${status_json}" ] && command -v jq >/dev/null 2>&1; then
      jq -r '"- cubie_runtime_gate: " + (.cubie_runtime_gate.status // "unknown"),
             "- a733_prereq_stack: " + (.a733_prereq_stack.status // "unknown"),
             "- local_offload: " + ((.local_offload.ok // false) | tostring)' "${status_json}" 2>/dev/null || true
    else
      echo "- status JSON unavailable"
    fi
    echo
    echo "## Actions Taken"
    echo
    echo "- Selected action: \`${action_label}\`"
    if [ -n "${action_command}" ]; then
      echo "- Executed: \`${action_command}\`"
    else
      echo "- No state-changing action selected."
    fi
    echo
    echo "## Command Transcript"
    echo
    echo '```text'
    sed -n '1,260p' "${transcript_file}"
    echo '```'
    echo
    echo "## Evidence Observed"
    echo
    echo "- Evidence is limited to the command transcript above and JSON files in \`${work_dir}\`."
    echo
    echo "## Remaining Blockers"
    echo
    if [ "${action_rc}" -ne 0 ]; then
      echo "- Selected action exited nonzero: \`${action_rc}\`."
    else
      echo "- Rerun the continuous cycle for the next status-derived action."
    fi
    echo
    echo "## Recommended Next Action"
    echo
    echo "\`safe-now\`: run the next bounded Hermes kernel work cycle."
  } >"${report_file}"

  cp "${transcript_file}" "${log_file}"
  if [ "${notify_enabled}" = "1" ]; then
    notify_message="Hermes kernel work cycle ${status}; rc=0; report=${report_file}; log=${log_file}"
    if ! notify_output="$("${hermes_bin}" send --to "${notify_target}" "${notify_message}" 2>&1)"; then
      echo "warning: Hermes kernel work notification failed: ${notify_output}" >&2
    fi
  fi
  echo "report=${report_file}"
  echo "log=${log_file}"
  exit 0
fi

set +e
if command -v timeout >/dev/null 2>&1; then
  timeout "${timeout_seconds}" "${hermes_bin}" --provider "${provider}" --model "${model}" --toolsets "${toolsets}" -z "${prompt}" >"${log_file}" 2>&1
  rc=$?
else
  python3 - "${hermes_bin}" "${timeout_seconds}" "${log_file}" "${prompt_snapshot}" "${toolsets}" "${provider}" "${model}" <<'PY'
from __future__ import annotations

import subprocess
import sys
from pathlib import Path

hermes = sys.argv[1]
timeout = int(sys.argv[2])
log = Path(sys.argv[3])
prompt = Path(sys.argv[4]).read_text(encoding="utf-8")
toolsets = sys.argv[5]
provider = sys.argv[6]
model = sys.argv[7]
with log.open("w", encoding="utf-8") as handle:
    try:
        proc = subprocess.run([hermes, "--provider", provider, "--model", model, "--toolsets", toolsets, "-z", prompt], stdout=handle, stderr=subprocess.STDOUT, timeout=timeout, check=False)
        raise SystemExit(proc.returncode)
    except subprocess.TimeoutExpired:
        handle.write("\nTIMEOUT\n")
        raise SystemExit(124)
PY
  rc=$?
fi
set -e

status="completed"
if [ "${rc}" -eq 124 ]; then
  status="timeout"
elif [ "${rc}" -ne 0 ]; then
  status="failed"
fi

{
  echo "# Hermes Kernel Work Cycle"
  echo
  echo "Generated: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
  echo "Status: \`${status}\`"
  echo "Return code: \`${rc}\`"
  echo "Prompt: \`${prompt_file}\`"
  echo "Prompt snapshot: \`${prompt_snapshot}\`"
  echo "Cubie access tier: \`${cubie_access_tier}\`"
  echo "Toolsets: \`${toolsets}\`"
  echo "Provider: \`${provider}\`"
  echo "Model: \`${model}\`"
  echo "Log: \`${log_file}\`"
  echo
  echo "## Output"
  echo
  echo '```text'
  sed -n '1,240p' "${log_file}"
  echo '```'
} >"${report_file}"

if [ "${notify_enabled}" = "1" ]; then
  notify_message="Hermes kernel work cycle ${status}; rc=${rc}; report=${report_file}; log=${log_file}"
  if ! notify_output="$("${hermes_bin}" send --to "${notify_target}" "${notify_message}" 2>&1)"; then
    echo "warning: Hermes kernel work notification failed: ${notify_output}" >&2
  fi
fi

echo "report=${report_file}"
echo "log=${log_file}"
exit "${rc}"
