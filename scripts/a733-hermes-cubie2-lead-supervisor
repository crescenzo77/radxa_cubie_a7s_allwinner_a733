def main():
    state = load_state()
    paths = []
    for run_index in range(MAX_LEADS_PER_RUN):
        stamp = dt.datetime.now(dt.timezone.utc).strftime("%Y%m%dT%H%M%SZ")
        if MAX_LEADS_PER_RUN > 1:
            stamp = f"{stamp}-r{run_index + 1}"
        context = collect_context()
        lead = next_lead(state, context)
        if TEST_MODE == "execute":
            run_result = run_lead(lead)
        else:
            run_result = {
                "return_code": 0,
                "result": "proposed_only",
                "uart_log": "",
                "output": "propose-only mode: Hermes documented this lead but did not boot Cubie2 or write registers.",
            }
        state.setdefault("completed", {})[lead["id"]] = {
            "stamp": stamp,
            "result": run_result["result"],
            "uart_log": run_result.get("uart_log", ""),
        }
        state.setdefault("runs", []).append({"stamp": stamp, "lead": lead["id"], "result": run_result["result"]})
        save_state(state)
        reviews = model_reviews(lead, run_result, state, context)
        paths.extend(write_reports(stamp, lead, run_result, state, context, reviews))
        if run_result["result"] == "no_uart_log":
            break
    print("A733 Cubie2 lead supervisor complete")
    for path in paths:
        print(path)


if __name__ == "__main__":
    try:
        main()
    except Exception as exc:
        OUT_DIR.mkdir(parents=True, exist_ok=True)
        stamp = dt.datetime.now(dt.timezone.utc).strftime("%Y%m%dT%H%M%SZ")
        path = OUT_DIR / f"{stamp}-a733-cubie2-lead-error.txt"
        path.write_text(str(exc) + "\n", encoding="utf-8")
        print(path)
        raise
