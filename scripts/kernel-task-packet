#!/usr/bin/env python3
"""Create a kernel patch-intent task packet.

This is the human-readable gate before any model is asked to edit code.
"""

import argparse
import datetime as dt
import json
import os
import re
import sys


REPO_ROOT = os.path.abspath(os.path.join(os.path.dirname(__file__), ".."))
DEFAULT_DIR = os.path.join(REPO_ROOT, "task-packets", "kernel")
BOARDS = {
    "cubie2": "192.168.50.85",
    "cubie3": "192.168.50.95",
    "none": None,
}


def slugify(value):
    value = value.lower().strip()
    value = re.sub(r"[^a-z0-9_.-]+", "-", value)
    return value.strip("-") or "task"


def utc_now():
    return dt.datetime.now(dt.timezone.utc).isoformat().replace("+00:00", "Z")


def main():
    parser = argparse.ArgumentParser(description="Create a kernel patch-intent task packet.")
    parser.add_argument("task_id", help="Short stable ID, e.g. a733-uart-aliases")
    parser.add_argument("--title", required=True)
    parser.add_argument("--board", choices=sorted(BOARDS), default="none")
    parser.add_argument("--subsystem", default="")
    parser.add_argument("--base-commit", default="")
    parser.add_argument("--target-file", action="append", default=[])
    parser.add_argument("--evidence", action="append", default=[])
    parser.add_argument("--non-goal", action="append", default=[])
    parser.add_argument("--proof", action="append", default=[])
    parser.add_argument("--out-dir", default=DEFAULT_DIR)
    parser.add_argument("--force", action="store_true")
    args = parser.parse_args()

    os.makedirs(args.out_dir, exist_ok=True)
    task_id = slugify(args.task_id)
    path = os.path.join(args.out_dir, f"{task_id}.json")
    if os.path.exists(path) and not args.force:
        print(f"refusing to overwrite existing task packet: {path}", file=sys.stderr)
        return 1

    packet = {
        "schema_version": 1,
        "task_id": task_id,
        "created_at": utc_now(),
        "title": args.title,
        "status": "draft",
        "board": {
            "name": None if args.board == "none" else args.board,
            "ip": BOARDS[args.board],
        },
        "problem_statement": "",
        "affected_subsystem": args.subsystem,
        "expected_maintainer_route": "",
        "base_commit": args.base_commit,
        "target_branch": "",
        "target_files": args.target_file,
        "allowed_path_set": args.target_file,
        "evidence_sources": args.evidence,
        "hardware_affected": [args.board] if args.board != "none" else [],
        "user_visible_or_abi_impact": "",
        "series_scope": "single patch unless updated by human",
        "explicit_non_goals": args.non_goal,
        "expected_proof_commands": args.proof,
        "max_repair_attempts": 2,
        "stop_conditions": [
            "hardware value lacks evidence",
            "subsystem placement is uncertain",
            "patch split is unclear",
            "validation failure persists after max_repair_attempts",
            "UART or power evidence conflicts with the code change",
        ],
        "ai_provenance": {
            "models_allowed": [],
            "dispatcher": "Codex Desktop",
            "local_endpoints": [
                "192.168.50.252:127.0.0.1:8001",
                "192.168.50.252:127.0.0.1:8092",
                "192.168.50.11:127.0.0.1:8082",
            ],
        },
        "token_offload_gate": {
            "codex_role": "dispatcher and verifier",
            "required_before_large_context": True,
            "large_context_thresholds": {
                "diff_lines": 200,
                "log_lines": 100,
                "mail_thread_messages": 3,
                "datasheet_pages": 1,
            },
            "required_context_cards": [
                "kernel-research-query for upstream overlap",
                "kernel-diff-brief before reading large diffs",
                "kernel-log-triage before reading long validation logs",
                "kernel-review-matrix before human promotion gates",
            ],
            "local_lanes": {
                "amd_rtx3090": {
                    "host": "192.168.50.252",
                    "endpoint": "http://127.0.0.1:8001/v1",
                    "role": "fast triage and first-pass diff/log review",
                },
                "amd_rx7900xt": {
                    "host": "192.168.50.252",
                    "endpoint": "http://127.0.0.1:8092/v1",
                    "role": "research synthesis, overlap checks, secondary review",
                },
                "strix": {
                    "host": "192.168.50.11",
                    "endpoint": "http://127.0.0.1:8082/v1",
                    "role": "long-context maintainer-style tertiary review",
                },
            },
        },
        "human_gate": {
            "signed_off_by_allowed": False,
            "send_email_allowed": False,
            "candidate_branch_promotion_allowed": False,
        },
    }

    with open(path, "w", encoding="utf-8") as handle:
        json.dump(packet, handle, indent=2, sort_keys=True)
        handle.write("\n")

    print(path)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
