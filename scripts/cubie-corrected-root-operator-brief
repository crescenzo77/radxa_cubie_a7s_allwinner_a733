#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

next_action="$("${repo_root}/scripts/kernel-workflow-status" --maintainer-next-action)"
blockers="$("${repo_root}/scripts/kernel-workflow-status" --maintainer-ready-blockers)"
backup_status="$("${repo_root}/scripts/kernel-workflow-status" --workflow-backup-status)"
waiting_actions="$("${repo_root}/scripts/kernel-workflow-status" --dispatcher-waiting-actions)"

cat <<BRIEF
# Cubie Corrected-Root Operator Brief

Maintainer-path next action:

\`\`\`sh
${next_action}
\`\`\`

Current maintainer-readiness blockers:

\`\`\`text
${blockers}
\`\`\`

Workflow backup posture:

\`\`\`text
${backup_status}
\`\`\`

Safe dispatcher actions while waiting:

\`\`\`text
${waiting_actions}
\`\`\`

Read-only install/session preflight:

\`\`\`text
BRIEF

"${repo_root}/scripts/cubie-interactive-root-install-session" \
  --confirm-target-ip 192.168.50.95 \
  --dry-run

cat <<'BRIEF'
```

Live U-Boot step, RAM only:

```text
setenv drm_debug 1
run bootcmd
```

Select this non-default U-Boot menu label:

```text
A733 v4 abc8d07b0a63 PARTUUID ro proof
```

After the UART session exits, proof gates:

```sh
scripts/cubie-corrected-root-proof-gate-selftest
scripts/cubie-latest-corrected-root-proof --strict
scripts/kernel-workflow-status --maintainer-ready-blockers
scripts/a733-patch-prep-checklist --run
```

While waiting on live hardware, safe non-hardware preflight:

```sh
scripts/a733-patch-prep-checklist --preflight
```

Do not claim runtime proof, reshape patches, or prepare maintainer-facing
submission material unless the corrected-root proof gate selftest and the
captured-log proof gate both pass.
BRIEF
