#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

validation_host="${VALIDATION_HOST:-192.168.50.252}"
remote_root="${VALIDATION_REMOTE_ROOT:-/srv/projects/kernel-proof}"
validation_workspace="${VALIDATION_WORKSPACE:-${remote_root}/scratch}"
image="${VALIDATION_IMAGE:-local/kernel-build-validate:20260606}"
context_dir="${repo_root}/validation/build-validate"
runner="${repo_root}/tools/validate/proof_runner.py"

usage() {
  cat <<USAGE
Usage: scripts/kernel-proof ACTION [args]

Actions:
  deploy          Copy the validation Docker context to the Linux host.
  build-image     Build the validation image on the Linux host.
  status          Show image and proof-log status on the Linux host.
  self-test       Run version, dummy PASS, and expected dummy FAIL proofs.
  run [args]      Run kernel-proof-runner in the validation container.
  pull-logs       Copy remote proof logs into tools/proof-logs/.

Defaults:
  VALIDATION_HOST=${validation_host}
  VALIDATION_REMOTE_ROOT=${remote_root}
  VALIDATION_WORKSPACE=${validation_workspace}
  VALIDATION_IMAGE=${image}

The Mac does not run containers. This script uses SSH to the IP above.
USAGE
}

ssh_target() {
  ssh -o BatchMode=yes -o ConnectTimeout=10 "${validation_host}" "$@"
}

deploy() {
  ssh_target "mkdir -p '${remote_root}/context' '${remote_root}/proof-logs' '${remote_root}/scratch'"
  COPYFILE_DISABLE=1 tar --format ustar -C "${context_dir}" -cf - Dockerfile \
    | ssh_target "tar -C '${remote_root}/context' -xf -"
  COPYFILE_DISABLE=1 tar --format ustar -C "$(dirname "${runner}")" -cf - "$(basename "${runner}")" \
    | ssh_target "tar -C '${remote_root}/context' -xf -"
  echo "deployed to ${validation_host}:${remote_root}/context"
}

build_image() {
  ssh_target "docker build -t '${image}' '${remote_root}/context'"
}

docker_run_prefix() {
  case "${validation_workspace}" in
    *[Tt][Ee][Ll][Ee][Gg][Rr][Aa][Mm]*|/home/*|"$HOME"/*)
      echo "refusing unsafe validation workspace: ${validation_workspace}" >&2
      exit 2
      ;;
  esac

  cat <<EOF
docker run --rm --network none \\
  --user "\$(id -u):\$(id -g)" \\
  --tmpfs /tmp:rw,nosuid,nodev,noexec,size=512m \\
  -v '${remote_root}/proof-logs:/proof-logs' \\
  -v '${validation_workspace}:/workspace' \\
  '${image}'
EOF
}

run_proof() {
  local quoted_args=()
  local arg
  for arg in "$@"; do
    quoted_args+=("$(printf "%q" "${arg}")")
  done

  local remote_cmd
  remote_cmd="$(docker_run_prefix) ${quoted_args[*]}"
  ssh_target "${remote_cmd}"
}

status() {
  ssh_target "set -e
echo host=\$(hostname)
echo ssh_target='${validation_host}'
echo remote_root='${remote_root}'
echo validation_workspace='${validation_workspace}'
echo image='${image}'
echo
docker image inspect '${image}' --format 'image_id={{.Id}} created={{.Created}} size={{.Size}}' 2>/dev/null || echo 'image=missing'
echo
find '${remote_root}/proof-logs' -maxdepth 1 -type f -name '*.json' -printf '%TY-%Tm-%Td %TH:%TM %p\n' 2>/dev/null | sort | tail -20 || true"
}

self_test() {
  deploy
  build_image

  echo
  echo "== version proof =="
  run_proof --task-id harness-selftest --check version-report

  echo
  echo "== dummy pass proof =="
  run_proof --task-id harness-selftest --check dummy-pass

  echo
  echo "== dummy fail proof, expected nonzero =="
  set +e
  run_proof --task-id harness-selftest --check dummy-fail
  local code=$?
  set -e
  if [ "${code}" -eq 7 ]; then
    echo "expected failure captured with exit_code=7"
  else
    echo "FAIL: dummy failure returned unexpected exit code ${code}" >&2
    exit 1
  fi

  echo
  status
}

pull_logs() {
  local local_dir="${repo_root}/tools/proof-logs"
  mkdir -p "${local_dir}"
  scp -q "${validation_host}:${remote_root}/proof-logs/"'*.json' "${local_dir}/" 2>/dev/null || true
  echo "proof logs copied to ${local_dir}"
}

action="${1:-status}"
if [ "$#" -gt 0 ]; then
  shift
fi

case "${action}" in
  deploy)
    deploy
    ;;
  build-image)
    deploy
    build_image
    ;;
  status)
    status
    ;;
  self-test)
    self_test
    ;;
  run)
    run_proof "$@"
    ;;
  pull-logs)
    pull_logs
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
