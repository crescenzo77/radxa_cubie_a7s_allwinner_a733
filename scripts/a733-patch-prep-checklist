#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
public_repo="${KERNEL_PUBLIC_REPO:-/Users/enzo/projects/Home Lab/cubie-a7s-armbian}"

usage() {
  cat <<USAGE
usage: $(basename "$0") [--run|--preflight]

Without arguments, print the read-only checklist. With --run, execute the
patch-prep gates in order and stop on the first failure. With --preflight,
execute only read-only dispatcher, backup, and Cubie session dry-run checks
that do not install files or require the live Cubie runtime proof to have
passed.
USAGE
}

run=0
preflight=0
case "${1:-}" in
  "")
    ;;
  --run)
    run=1
    shift
    ;;
  --preflight)
    preflight=1
    shift
    ;;
  -h|--help)
    usage
    exit 0
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
if [ "$#" -ne 0 ]; then
  usage >&2
  exit 2
fi

run_gate() {
  local title="$1"
  shift
  printf '\n== %s ==\n' "${title}"
  "$@"
}

if [ "${preflight}" = "1" ]; then
  cd "${repo_root}"
  run_gate "dispatcher/offload smoke" \
    scripts/kernel-offload-status-smoke
  run_gate "backup posture" \
    scripts/kernel-workflow-status --workflow-backup-status
  run_gate "workflow dirty status" \
    scripts/kernel-workflow-status --workflow-dirty-status
  run_gate "A733 RFC overlap freshness" \
    scripts/kernel-workflow-status --a733-rfc-recheck-status
  run_gate "corrected-root proof gate selftest" \
    scripts/cubie-corrected-root-proof-gate-selftest
  run_gate "A733 series shape gate selftest" \
    scripts/a733-series-shape-gate-selftest
  run_gate "A733 prerequisite API audit" \
    scripts/a733-prereq-api-audit "${public_repo}/patches"
  run_gate "backup approval brief" \
    scripts/kernel-backup-approval-brief
  run_gate "dispatcher stopping-point audit" \
    scripts/kernel-workflow-status --stopping-point-audit
  run_gate "Cubie corrected-root session dry-run" \
    scripts/cubie-interactive-root-install-session --confirm-target-ip 192.168.50.95 --dry-run
  run_gate "Strix-dispatched Cubie proof dry-run" \
    scripts/cubie-strix-live-proof-dry-run
  printf '\nA733 patch-prep preflight gates passed.\n'
  printf '\nNext live action:\n'
  scripts/kernel-workflow-status --maintainer-next-action
  exit 0
fi

if [ "${run}" = "1" ]; then
  cd "${repo_root}"
  run_gate "exact v4 Cubie runtime proof" \
    scripts/cubie-latest-corrected-root-proof --strict
  run_gate "dispatcher/offload smoke" \
    scripts/kernel-offload-status-smoke
  run_gate "A733 RFC overlap freshness" \
    scripts/kernel-workflow-status --a733-rfc-recheck-status
  run_gate "corrected-root proof gate selftest" \
    scripts/cubie-corrected-root-proof-gate-selftest
  run_gate "A733 series shape gate selftest" \
    scripts/a733-series-shape-gate-selftest
  run_gate "maintainer-ready workflow gate" \
    scripts/kernel-workflow-status --maintainer-ready-strict
  run_gate "A733 series shape gate" \
    scripts/a733-series-shape-gate "${public_repo}/patches"
  run_gate "A733 prerequisite API audit" \
    scripts/a733-prereq-api-audit "${public_repo}/patches"
  run_gate "public hygiene gate" \
    scripts/kernel-public-hygiene-gate "${public_repo}"
  run_gate "backup posture" \
    scripts/kernel-workflow-status --workflow-backup-status
  printf '\nA733 patch-prep gates passed.\n'
  exit 0
fi

cat <<CHECKLIST
# A733 Patch Prep Checklist

Run these gates after the corrected-root runtime proof passes and before
creating any maintainer-facing branch, patch export, cover letter, or mail.

To execute the gates in order:

   cd ${repo_root} && scripts/a733-patch-prep-checklist --run

To check read-only dispatcher, backup, and Cubie session readiness while waiting:

   cd ${repo_root} && scripts/a733-patch-prep-checklist --preflight

1. Exact v4 Cubie runtime proof:

   cd ${repo_root} && scripts/cubie-latest-corrected-root-proof --strict

2. Dispatcher/offload smoke:

   cd ${repo_root} && scripts/kernel-offload-status-smoke

3. Maintainer-ready workflow gate:

   cd ${repo_root} && scripts/kernel-workflow-status --maintainer-ready-strict

4. A733 series shape gate selftest:

   cd ${repo_root} && scripts/a733-series-shape-gate-selftest

5. A733 series shape gate on the public export:

   cd ${repo_root} && scripts/a733-series-shape-gate "${public_repo}/patches"

6. A733 RFC overlap freshness:

   cd ${repo_root} && scripts/kernel-workflow-status --a733-rfc-recheck-status

   This must be fresh before maintainer-facing patch prep. If it is stale,
   refresh the public A733 CCU/pinctrl overlap scan and keep local CCU/pinctrl
   patches out of the sendable slice unless maintainers request otherwise.

7. A733 prerequisite API audit:

   cd ${repo_root} && scripts/a733-prereq-api-audit "${public_repo}/patches"

   This must pass before regenerating a candidate branch. It catches review
   exports that have the right patch shape but still mismatch the active
   CCU/pinctrl/MMC prerequisite APIs.

8. Public hygiene gate:

   cd ${repo_root} && scripts/kernel-public-hygiene-gate "${public_repo}"

9. Corrected-root proof gate selftest:

   cd ${repo_root} && scripts/cubie-corrected-root-proof-gate-selftest

   This guards the exact-v4 UART proof classifier before any captured log is
   treated as maintainer evidence.

10. Backup posture:

   cd ${repo_root} && scripts/kernel-workflow-status --workflow-backup-status

11. Workflow dirty status:

   cd ${repo_root} && scripts/kernel-workflow-status --workflow-dirty-status

12. Backup approval brief:

   cd ${repo_root} && scripts/kernel-backup-approval-brief

13. Cubie corrected-root session dry-run:

   cd ${repo_root} && scripts/cubie-interactive-root-install-session --confirm-target-ip 192.168.50.95 --dry-run

14. Strix-dispatched Cubie proof dry-run:

   cd ${repo_root} && scripts/cubie-strix-live-proof-dry-run

15. Dispatcher stopping-point audit:

   cd ${repo_root} && scripts/kernel-workflow-status --stopping-point-audit

The current public export is a narrow board binding + SoC DTSI + board DTS
review slice. A regenerated candidate may add one MMC binding patch if the
chosen base does not already document `allwinner,sun60i-a733-mmc`. It is still
not a mailed submission: regenerate it from the exact clean kernel branch
stacked on the current or accepted prerequisites, carry the active Depends-on
IDs for the A733 RTC, CCU, and pinctrl work, avoid vendor U-Boot workaround
state in DTS, and avoid Ethernet, VPU, display, wireless, USB-C, PCIe, and
other feature creep.
CHECKLIST
