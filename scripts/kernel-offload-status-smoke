#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

"${repo_root}/scripts/kernel-token-offload" status --json | python3 -c '
import json
import sys

data = json.load(sys.stdin)
required = {"amd-fast", "amd-research", "strix-review"}
targets = {item.get("name"): item for item in data.get("targets", [])}
missing = sorted(required.difference(targets))
unhealthy = sorted(name for name in required.intersection(targets) if not targets[name].get("ok"))
cortex = data.get("cortex", {})

if missing or unhealthy or not cortex.get("ok") or not data.get("ok"):
    print("ok=no")
    if missing:
        print("missing_targets=" + ",".join(missing))
    if unhealthy:
        print("unhealthy_targets=" + ",".join(unhealthy))
    if not cortex.get("ok"):
        print("cortex_error=" + str(cortex.get("error", "")))
    sys.exit(1)

print("ok=yes")
print("targets=" + ",".join(sorted(required)))
print("cortex=qdrant")
'
