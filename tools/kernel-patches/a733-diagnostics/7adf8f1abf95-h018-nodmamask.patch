From 7adf8f1abf95c0b7834e717bef1558aae4477e3e Mon Sep 17 00:00:00 2001
From: Enzo <enzo@homelab.local>
Date: Wed, 10 Jun 2026 13:46:30 -0400
Subject: [PATCH] mmc: replay A733 descriptor stamps without DMA mask

---
 drivers/mmc/host/sunxi-mmc.c | 8 --------
 1 file changed, 8 deletions(-)

diff --git a/drivers/mmc/host/sunxi-mmc.c b/drivers/mmc/host/sunxi-mmc.c
index fd64bdc4f06b..b1b0fac87aab 100644
--- a/drivers/mmc/host/sunxi-mmc.c
+++ b/drivers/mmc/host/sunxi-mmc.c
@@ -2042,14 +2042,6 @@ static int sunxi_mmc_probe(struct platform_device *pdev)
 	if (ret)
 		return ret;
 
-	if (of_device_is_compatible(pdev->dev.of_node, "allwinner,sun60i-a733-mmc")) {
-		ret = dma_set_mask_and_coherent(&pdev->dev, DMA_BIT_MASK(64));
-		if (ret)
-			return dev_err_probe(&pdev->dev, ret,
-					     "Failed to set A733 diagnostic DMA mask\n");
-		dev_info(&pdev->dev, "diag A733 DMA mask set to 64 bits\n");
-	}
-
 	if (host->cfg->diag_idma_low_desc_mask) {
 		ret = dma_set_coherent_mask(&pdev->dev, DMA_BIT_MASK(30));
 		if (ret)
-- 
2.53.0

